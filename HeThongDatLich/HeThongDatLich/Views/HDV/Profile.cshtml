@model HeThongDatLich.Models.HOSOHDV
@{
    Layout = "~/Views/Shared/_LayoutHDV.cshtml";
    ViewData["Title"] = "Hồ sơ của tôi";
    var fullName = Model.NguoiDung?.HoTen ?? "Nguyễn Văn A";
    var firstLetter = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "H";
}
<div class="profile-container">
    <div class="row">
        <div class="col-md-4 text-center">
            <div class="card p-4 mb-3">
                <div class="display-1 bg-light rounded-circle mx-auto mb-3" style="width: 120px; height: 120px; line-height: 120px;">@firstLetter</div>
                <h3>@fullName</h3>
                <p class="text-muted">Hướng dẫn viên Chuyên nghiệp</p>
                <p><i class="fas fa-map-marker-alt"></i> @(Model.PhuongXa?.TinhThanh?.TenTinh ?? "Đà Nẵng, Việt Nam")</p>
                <div class="rating fs-5">⭐ @ViewBag.AvgRating.ToString("F1")/5.0</div>
                <hr />
                <div><strong>Tours Completed</strong><br />@ViewBag.ToursCompleted</div>
                <div><strong>Total Earnings</strong><br />@ViewBag.TotalEarnings.ToString("C0")</div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card p-4 mb-3">
                <h4>Thông tin cá nhân</h4>
                <div class="row">
                    <div class="col-sm-6"><strong>Full Name:</strong> @Model.NguoiDung?.HoTen</div>
                    <div class="col-sm-6"><strong>Email:</strong> @Model.NguoiDung?.Email</div>
                    <div class="col-sm-6"><strong>Phone:</strong> @Model.NguoiDung?.SoDienThoai</div>
                    <div class="col-sm-6"><strong>Date of Birth:</strong> 15/05/1997</div>
                </div>
            </div>
            <div class="card p-4 mb-3">
                <h4>Verification</h4>
                <p><strong>Verified on:</strong> 12/01/2023</p>
                <p><strong>First Aid Certificate:</strong> Verified on 05/03/2023</p>
            </div>
            <div class="card p-4 mb-3">
                <h4>Professional Details</h4>
                <p><strong>Specialization:</strong> @(Model.GioiThieu ?? "Food tours")</p>
                <p><strong>Kinh nghiệm:</strong> @Model.KinhNghiem năm</p>
            </div>
            <div class="card p-4 mb-3">
                <h4>Languages</h4>
                <p>@(Model.NgonNgu?.TenNgonNgu ?? "Tiếng Việt, English")</p>
            </div>
            <div class="card p-4">
                <h4>Bank Account</h4>
                <p><strong>VIETCOMBANK</strong> **** **** **** 8888</p>
                <p>Account holder: @fullName.ToUpper()</p>
                <button class="btn btn-outline-primary mt-2">Change payout method</button>
            </div>
        </div>
    </div>
</div>