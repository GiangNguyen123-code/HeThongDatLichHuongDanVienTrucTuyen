@model HeThongDatLich.Models.HOSOHDV
@{
    Layout = "~/Views/Shared/_LayoutHDV.cshtml";
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Cập nhật hồ sơ Hướng dẫn viên</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post">
                        <input type="hidden" asp-for="MaHDV" />
                        <input type="hidden" asp-for="NguoiDung.MaNguoiDung" />

                        <h6 class="text-muted mb-3">Thông tin tài khoản</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Họ và tên</label>
                                <!-- Cần sử dụng name="HoTen" để truyền riêng vào hàm POST do nằm ở bảng NGUOIDUNG -->
                                <input type="text" name="HoTen" class="form-control" value="@Model.NguoiDung?.HoTen" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Số điện thoại</label>
                                <input type="text" name="SoDienThoai" class="form-control" value="@Model.NguoiDung?.SoDienThoai" />
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h6 class="text-muted mb-3">Thông tin nghề nghiệp (HDV)</h6>

                        <div class="mb-3">
                            <label asp-for="GioiThieu" class="form-label fw-bold">Giới thiệu bản thân / Sở trường</label>
                            <textarea asp-for="GioiThieu" class="form-control" rows="4" placeholder="Ví dụ: Chuyên tour ẩm thực, lịch sử..."></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="KinhNghiem" class="form-label fw-bold">Kinh nghiệm (Năm)</label>
                                <input asp-for="KinhNghiem" type="number" min="0" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GiaThue" class="form-label fw-bold">Giá thuê cơ bản (VNĐ/Ngày)</label>
                                <input asp-for="GiaThue" type="number" step="10000" class="form-control" required />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="MaNgonNgu" class="form-label fw-bold">Ngôn ngữ chính</label>
                                <select asp-for="MaNgonNgu" class="form-select" asp-items="ViewBag.MaNgonNgu"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MaPhuongXa" class="form-label fw-bold">Khu vực hoạt động</label>
                                <select asp-for="MaPhuongXa" class="form-select" asp-items="ViewBag.MaPhuongXa"></select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Profile" class="btn btn-secondary">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>