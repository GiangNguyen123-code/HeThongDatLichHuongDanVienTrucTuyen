@model IEnumerable<HeThongDatLich.Models.DONDATLICH>
@{
    ViewData["Title"] = "Quản lý chuyến đi";
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
}

<style>
    .booking-history-container {
        max-width: 1000px;
        margin: 40px auto 80px;
        padding: 0 20px;
    }

    .page-header {
        margin-bottom: 30px;
    }
    .page-header h2 {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }
    .page-header p {
        color: #64748b;
        font-size: 15px;
    }

    /* Hệ thống Tabs ngang mượt mà */
    .tabs-wrapper {
        display: flex;
        gap: 8px;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 30px;
        padding-bottom: 4px;
        overflow-x: auto;
    }
    .tab-btn {
        background: none;
        border: none;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.2s;
        white-space: nowrap;
        position: relative;
    }
    .tab-btn:hover {
        color: #0f172a;
        background: #f1f5f9;
    }
    .tab-btn.active {
        color: #2563eb;
        background: #eff6ff;
    }

    /* Thiết kế Thẻ Chuyến đi (Booking Card) */
    .booking-card {
        background: #ffffff;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.02);
        border: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s ease;
    }
    .booking-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        border-color: #e2e8f0;
    }

    .card-left {
        display: flex;
        gap: 20px;
        align-items: center;
    }
    .guide-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f1f5f9;
    }

    .info-title {
        font-size: 16px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }
    .info-tour {
        font-size: 14px;
        font-weight: 500;
        color: #475569;
        margin-bottom: 6px;
    }
    .info-meta {
        font-size: 13px;
        color: #94a3b8;
        display: flex;
        gap: 15px;
    }
    .info-meta span {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Badge Trạng thái mềm mại pastel */
    .status-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid;
    }
    .status-1 { background: #fef3c7; color: #d97706; border-color: #fcd34d; } /* Chờ duyệt */
    .status-2 { background: #e0f2fe; color: #0369a1; border-color: #7dd3fc; } /* Đã chốt */
    .status-3 { background: #dcfce7; color: #15803d; border-color: #86efac; } /* Hoàn thành */
    .status-4 { background: #fee2e2; color: #b91c1c; border-color: #fca5a5; } /* Đã hủy */

    .status-responded {
        background: #eff6ff;
        color: #2563eb;
        border-color: #bfdbfe;
    }

    .card-right {
        text-align: right;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        min-width: 220px;
    }
    .total-price {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
        margin: 12px 0;
    }
    
    .action-group {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    /* Nút hành động */
    .btn-action-detail {
        background: #fff;
        color: #475569;
        border: 1.5px solid #cbd5e1;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }
    .btn-action-detail:hover {
        background: #f8fafc;
        border-color: #94a3b8;
        color: #0f172a;
    }

    .btn-action-review {
        background: #2563eb;
        color: white;
        border: none;
        padding: 9px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
    }
    .btn-action-review:hover {
        background: #1d4ed8;
        transform: translateY(-1px);
    }
    
    /* Giao diện Modal Popup */
    .custom-modal {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.2s ease;
    }
    .modal-box {
        background: white;
        border-radius: 24px;
        width: 100%;
        max-width: 480px;
        padding: 32px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        position: relative;
    }
    .modal-close {
        position: absolute; top: 20px; right: 20px;
        background: none; border: none; font-size: 24px; color: #94a3b8; cursor: pointer;
        line-height: 1;
    }
    .modal-close:hover { color: #0f172a; }
    .modal-box h4 { font-size: 20px; font-weight: 800; color: #0f172a; margin-bottom: 24px; }
    
    /* Cấu trúc dòng thông tin trong Modal Chi Tiết */
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px dashed #e2e8f0;
        font-size: 14px;
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: #64748b; font-weight: 500; }
    .detail-value { color: #0f172a; font-weight: 700; text-align: right; max-width: 60%; }

    /* Chọn sao Đánh giá */
    .star-rating-select {
        display: flex; gap: 8px; flex-direction: row-reverse; justify-content: center; margin-bottom: 20px;
    }
    .star-rating-select input { display: none; }
    .star-rating-select label { font-size: 32px; color: #e2e8f0; cursor: pointer; transition: 0.15s; }
    .star-rating-select input:checked ~ label,
    .star-rating-select label:hover,
    .star-rating-select label:hover ~ label { color: #fbbf24; }

    .textarea-custom {
        width: 100%; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 12px;
        font-size: 14px; outline: none; margin-bottom: 20px; resize: none;
    }
    .textarea-custom:focus { border-color: #2563eb; }

    /* Thông báo xanh dương */
    .blue-alert {
        background: #f0f9ff;
        color: #0369a1;
        border: 1px solid #7dd3fc;
        border-radius: 16px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        font-weight: 600;
        font-size: 16px;
    }

    @@keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
</style>

<div class="booking-history-container">
    
    <div class="page-header">
        <h2>Chuyến đi của tôi</h2>
        <p>Theo dõi trạng thái lịch trình và để lại phản hồi cho hướng dẫn viên của bạn.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="blue-alert">
            <i class="fa-solid fa-circle-check fs-5"></i>
            <div>@TempData["SuccessMessage"]</div>
        </div>
    }

    <div class="tabs-wrapper">
        <button class="tab-btn active" onclick="filterTab('all', this)">Tất cả chuyến</button>
        <button class="tab-btn" onclick="filterTab('1', this)">Chờ xác nhận</button>
        <button class="tab-btn" onclick="filterTab('2', this)">Đã xác nhận</button>
        <button class="tab-btn" onclick="filterTab('3', this)">Đã hoàn thành</button>
        <button class="tab-btn" onclick="filterTab('4', this)">Đã hủy/Từ chối</button>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 border border-dashed text-muted">
            <i class="fa-solid fa-suitcase-rolling mb-3" style="font-size: 44px; color: #cbd5e1;"></i>
            <h5>Bạn chưa thực hiện yêu cầu đặt lịch nào.</h5>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            string avatarURL = string.IsNullOrEmpty(item.HDV?.NguoiDung?.AnhDaiDien) || item.HDV?.NguoiDung?.AnhDaiDien == "Avatar_Text"
                ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(item.HDV?.NguoiDung?.HoTen ?? "H")}&background=random&size=150"
                : item.HDV.NguoiDung.AnhDaiDien;

            <div class="booking-card" data-status="@item.TrangThai">
                <div class="card-left">
                    <img src="@avatarURL" class="guide-avatar" alt="Avatar">
                    <div>
                        <div class="info-title">HDV: @(item.HDV?.NguoiDung?.HoTen ?? "Hướng dẫn viên")</div>
                        <div class="info-tour"><i class="fa-solid fa-route text-primary me-1"></i> @(item.GoiTour?.TenTour ?? "Thuê HDV tự do theo ngày")</div>
                        <div class="info-meta">
                            <span><i class="fa-regular fa-calendar"></i> @item.NgayDat.ToString("dd/MM/yyyy")</span>
                            <span><i class="fa-regular fa-clock"></i> @item.KhungGio</span>
                        </div>
                        @if (item.TrangThai == 4 && !string.IsNullOrEmpty(item.GhiChu) && item.GhiChu.Contains("Lý do hủy:"))
                        {
                            <div class="mt-2 text-danger" style="font-size: 13px; font-weight: 500;">
                                <i class="fa-solid fa-circle-info"></i> @item.GhiChu.Substring(item.GhiChu.IndexOf("Lý do hủy:"))
                            </div>
                        }
                    </div>
                </div>

                <div class="card-right">
                    <div>
                        @if (item.TrangThai == 1) { <span class="status-badge status-1"><i class="fa-regular fa-hourglass"></i> Chờ xác nhận</span> }
                        else if (item.TrangThai == 2) { <span class="status-badge status-2"><i class="fa-regular fa-calendar-check"></i> Đã xác nhận</span> }
                        else if (item.TrangThai == 3) { <span class="status-badge status-3"><i class="fa-regular fa-circle-check"></i> Đã xong</span> }
                        else if (item.TrangThai == 4) { <span class="status-badge status-4"><i class="fa-regular fa-circle-xmark"></i> Đã hủy</span> }
                    </div>
                    
                    <div class="total-price">@((item.HoaDon?.TongTien ?? 0).ToString("N0"))đ</div>
                    
                    <div class="action-group">
                        <button class="btn-action-detail" onclick="openModal('modal_detail_@item.MaDatLich')">Xem chi tiết</button>
                        
                        @if (item.TrangThai == 3)
                        {
                            if (!item.DanhGias.Any())
                            {
                                <button class="btn-action-review" onclick="openModal('modal_review_@item.MaDatLich')">Viết đánh giá</button>
                            }
                            else
                            {
                                <span class="status-badge status-responded px-3" style="font-size: 12px;"><i class="fas fa-check"></i> Đã phản hồi</span>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="custom-modal" id="modal_detail_@item.MaDatLich">
                <div class="modal-box">
                    <button class="modal-close" onclick="closeModal('modal_detail_@item.MaDatLich')">&times;</button>
                    <h4>Chi tiết Đơn đặt lịch #@item.MaDatLich</h4>
                    
                    <div class="detail-row">
                        <span class="detail-label">Hướng dẫn viên</span>
                        <span class="detail-value">@item.HDV?.NguoiDung?.HoTen</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Gói dịch vụ</span>
                        <span class="detail-value text-primary">@(item.GoiTour?.TenTour ?? "Thuê HDV tự do")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Thời gian thực hiện</span>
                        <span class="detail-value">@item.KhungGio, @item.NgayDat.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Phương thức thanh toán</span>
                        <span class="detail-value">@(item.HoaDon?.PhuongThucThanhToan?.TenPhuongThuc ?? "Chưa rõ")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Tình trạng thanh toán</span>
                        <span class="detail-value @(item.HoaDon?.TrangThaiTT == true ? "text-success" : "text-warning")">
                            @(item.HoaDon?.TrangThaiTT == true ? "Đã thanh toán" : "Chưa thanh toán")
                        </span>
                    </div>
                    @if (item.HoaDon?.SoTienGiam > 0)
                    {
                        <div class="detail-row">
                            <span class="detail-label">Mã giảm giá áp dụng</span>
                            <span class="detail-value text-success">-@((item.HoaDon?.SoTienGiam ?? 0).ToString("N0"))đ</span>
                        </div>
                    }
                    
                    @if (item.TrangThai == 4 && !string.IsNullOrEmpty(item.GhiChu))
                    {
                        <div class="detail-row" style="background-color: #fef2f2; padding: 12px 16px; border-radius: 8px; margin-top: 12px; border: 1px solid #fecaca;">
                            <span class="detail-label text-danger fw-bold"><i class="fa-solid fa-circle-info"></i> Lý do hủy</span>
                            <span class="detail-value text-danger">
                                @(item.GhiChu.Contains("Lý do hủy:") ? item.GhiChu.Substring(item.GhiChu.IndexOf("Lý do hủy:")).Replace("Lý do hủy:", "").Trim() : item.GhiChu)
                            </span>
                        </div>
                    }

                    <div class="detail-row border-0 mt-2 p-0">
                        <span class="detail-label fs-5">Tổng tiền</span>
                        <span class="detail-value fs-4 text-danger">@((item.HoaDon?.TongTien ?? 0).ToString("N0"))đ</span>
                    </div>
                </div>
            </div>

            @if (item.TrangThai == 3 && !item.DanhGias.Any())
            {
                <div class="custom-modal" id="modal_review_@item.MaDatLich">
                    <div class="modal-box">
                        <button class="modal-close" onclick="closeModal('modal_review_@item.MaDatLich')">&times;</button>
                        <h4 class="text-center">Đánh giá dịch vụ</h4>
                        <p class="text-muted small text-center mb-4">Hãy chia sẻ trải nghiệm của bạn với hướng dẫn viên @item.HDV?.NguoiDung?.HoTen</p>
                        
                        <form action="@Url.Action("GuiDanhGia", "KhachHangDonDat")" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="MaDatLich" value="@item.MaDatLich" />
                            
                            <div class="star-rating-select">
                                <input type="radio" id="star5_@item.MaDatLich" name="SoSao" value="5" required/><label for="star5_@item.MaDatLich">★</label>
                                <input type="radio" id="star4_@item.MaDatLich" name="SoSao" value="4" /><label for="star4_@item.MaDatLich">★</label>
                                <input type="radio" id="star3_@item.MaDatLich" name="SoSao" value="3" /><label for="star3_@item.MaDatLich">★</label>
                                <input type="radio" id="star2_@item.MaDatLich" name="SoSao" value="2" /><label for="star2_@item.MaDatLich">★</label>
                                <input type="radio" id="star1_@item.MaDatLich" name="SoSao" value="1" /><label for="star1_@item.MaDatLich">★</label>
                            </div>

                            <textarea name="NoiDung" class="textarea-custom" rows="4" placeholder="Nhập phản hồi chi tiết tại đây (ví dụ: nhiệt tình, chu đáo, am hiểu văn hóa...)" required></textarea>
                            
                            <button type="submit" style="width:100%; background:#2563eb; color:white; border:none; padding:12px; border-radius:12px; font-size:15px; font-weight:600; cursor:pointer; box-shadow:0 4px 12px rgba(37,99,235,0.2);">Gửi đánh giá</button>
                        </form>
                    </div>
                </div>
            }
        }
    }
</div>

<script>
    function filterTab(status, btn) {
        document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        const cards = document.querySelectorAll('.booking-card');
        cards.forEach(card => {
            if (status === 'all' || card.getAttribute('data-status') === status) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function openModal(id) {
        document.getElementById(id).style.display = 'flex';
    }

    function closeModal(id) {
        document.getElementById(id).style.display = 'none';
    }

    window.onclick = function(event) {
        if (event.target.classList.contains('custom-modal')) {
            event.target.style.display = 'none';
        }
    }
</script>