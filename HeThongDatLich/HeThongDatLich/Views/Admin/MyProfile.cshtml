@model HeThongDatLich.Models.NGUOIDUNG

@{
    ViewData["Title"] = "My Profile";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>My Profile – Admin Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #f0f4f9;
            --sidebar-bg: #ffffff;
            --card-bg:   #ffffff;
            --blue:      #1a56db;
            --blue-dark: #1342b0;
            --blue-soft: #e8f0fe;
            --green:     #12b76a;
            --green-soft:#d1fadf;
            --red:       #f04438;
            --orange:    #f79009;
            --orange-soft:#fef3c7;
            --text:      #111827;
            --muted:     #6b7280;
            --border:    #e5e7eb;
            --radius:    12px;
            --sidebar-w: 220px;
            --font:      'Plus Jakarta Sans', sans-serif;
            --mono:      'DM Mono', monospace;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
            padding: 0 0 24px;
        }

        .sidebar-logo {
            padding: 22px 20px 18px;
            font-size: 18px;
            font-weight: 700;
            color: var(--blue);
            letter-spacing: -0.3px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-avatar {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: var(--blue-soft);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700;
            color: var(--blue);
            font-size: 14px;
            overflow: hidden;
        }
        .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .sidebar-profile-name { font-weight: 600; font-size: 13px; }
        .sidebar-profile-role { font-size: 11px; color: var(--muted); margin-top: 2px; }

        .sidebar-nav { flex: 1; padding: 12px 10px; }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 13.5px; font-weight: 500;
            color: var(--muted);
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
        }
        .nav-item:hover { background: var(--bg); color: var(--text); }
        .nav-item.active { background: var(--blue-soft); color: var(--blue); font-weight: 600; }
        .nav-item svg { flex-shrink: 0; }

        .sidebar-footer { padding: 0 10px; }
        .btn-create-tour {
            width: 100%;
            background: var(--blue);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 11px 0;
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 10px;
            transition: background 0.15s;
        }
        .btn-create-tour:hover { background: var(--blue-dark); }
        .nav-help {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--muted);
            cursor: pointer;
            border-radius: 8px;
        }
        .nav-help:hover { background: var(--bg); color: var(--text); }

        /* ── MAIN ── */
        .main {
            margin-left: var(--sidebar-w);
            flex: 1;
            padding: 28px 28px 40px;
            display: grid;
            grid-template-columns: 1fr 360px;
            gap: 20px;
            align-items: start;
        }

        .left-col { display: flex; flex-direction: column; gap: 18px; }

        /* ── PROFILE HEADER CARD ── */
        .profile-header-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 22px 24px;
            display: flex;
            align-items: center;
            gap: 20px;
            animation: fadeUp 0.4s ease both;
        }
        .profile-avatar-wrap {
            position: relative;
            flex-shrink: 0;
        }
        .profile-avatar-wrap img {
            width: 80px; height: 80px;
            border-radius: 14px;
            object-fit: cover;
            display: block;
        }
        .avatar-placeholder {
            width: 80px; height: 80px;
            border-radius: 14px;
            background: linear-gradient(135deg, #c7d7f5, #a5bfee);
            display: flex; align-items: center; justify-content: center;
            font-size: 28px; font-weight: 700; color: var(--blue);
        }
        .avatar-badge {
            position: absolute;
            bottom: -6px; right: -6px;
            background: var(--blue);
            border-radius: 50%;
            width: 22px; height: 22px;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid #fff;
        }
        .avatar-badge svg { width: 11px; height: 11px; }

        .profile-info { flex: 1; }
        .profile-name {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.4px;
            margin-bottom: 6px;
        }
        .profile-tags { display: flex; align-items: center; gap: 10px; }
        .badge-role {
            background: var(--blue);
            color: #fff;
            font-size: 11.5px;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 20px;
        }
        .badge-status {
            display: flex; align-items: center; gap: 5px;
            font-size: 12.5px; color: var(--green); font-weight: 500;
        }
        .status-dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 0 2px var(--green-soft);
            animation: pulse 2s infinite;
        }

        .profile-actions { display: flex; gap: 10px; margin-left: auto; }
        .btn-outline {
            display: flex; align-items: center; gap: 6px;
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            cursor: pointer;
            white-space: nowrap;
            transition: border-color 0.15s, background 0.15s;
        }
        .btn-outline:hover { border-color: var(--blue); background: var(--blue-soft); color: var(--blue); }
        .btn-solid {
            display: flex; align-items: center; gap: 6px;
            background: var(--blue);
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            white-space: nowrap;
            transition: background 0.15s;
        }
        .btn-solid:hover { background: var(--blue-dark); }

        /* ── CARD ── */
        .card {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 22px 24px;
            animation: fadeUp 0.4s ease both;
        }
        .card:nth-child(2) { animation-delay: 0.07s; }
        .card:nth-child(3) { animation-delay: 0.14s; }
        .card:nth-child(4) { animation-delay: 0.21s; }

        .card-title {
            display: flex; align-items: center; gap: 8px;
            font-size: 15px; font-weight: 700;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--border);
        }
        .card-title svg { color: var(--blue); }

        /* ── INFO GRID ── */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }
        .info-field label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 6px;
        }
        .info-value {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 9px 13px;
            font-size: 13.5px;
            font-weight: 500;
            display: flex; align-items: center; gap: 7px;
            color: var(--text);
        }
        .info-value svg { color: var(--muted); flex-shrink: 0; }
        .info-value span { font-family: var(--mono); font-size: 13px; }

        /* ── SECURITY ITEMS ── */
        .security-item {
                display: flex;
                align-items: flex-start;
                gap: 14px;
            padding: 14px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            margin-bottom: 10px;
            transition: border-color 0.15s;
        }
        .security-item:last-child { margin-bottom: 0; }
        .security-item:hover { border-color: var(--blue); }
        .sec-icon {
            width: 40px; height: 40px;
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .sec-icon.blue-soft { background: var(--blue-soft); color: var(--blue); }
        .sec-icon.orange-soft { background: var(--orange-soft); color: var(--orange); }

            .sec-body {
                flex: 1;
                padding-top: 2px;
            }
            .security-item button,
            .security-item .badge-active {
                flex-shrink: 0;
                align-self: center; /* Giữ nút nằm giữa theo chiều dọc */
                white-space: nowrap; /* Không cho chữ trong nút rớt dòng */
            }
        .sec-title { font-size: 13.5px; font-weight: 600; margin-bottom: 3px; }
        .sec-desc { font-size: 12px; color: var(--muted); }
        .badge-active {
            display: flex; align-items: center; gap: 5px;
            background: var(--green-soft);
            color: var(--green);
            font-size: 11px; font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            white-space: nowrap;
        }
        .btn-link {
            background: none; border: none;
            color: var(--blue);
            font-size: 13px; font-weight: 600;
            cursor: pointer;
            padding: 0;
            white-space: nowrap;
        }
        .btn-link:hover { text-decoration: underline; }

        /* ── QUICK ACCESS ── */
        .quick-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }
        .quick-btn {
            display: flex; flex-direction: column; align-items: center;
            gap: 8px;
            padding: 14px 10px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            background: var(--bg);
            cursor: pointer;
            font-size: 12px; font-weight: 600; color: var(--text);
            text-align: center;
            transition: all 0.15s;
        }
        .quick-btn:hover {
            border-color: var(--blue);
            background: var(--blue-soft);
            color: var(--blue);
        }
        .quick-btn .qicon {
            width: 34px; height: 34px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            background: var(--blue-soft);
            color: var(--blue);
        }
        .quick-btn:hover .qicon {
            background: var(--blue);
            color: #fff;
        }

        /* ── RIGHT COLUMN: ACTIVITY LOG ── */
        .right-col { position: sticky; top: 28px; }
        .activity-card {
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 20px;
            animation: fadeUp 0.5s 0.1s ease both;
        }
        .activity-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 16px;
        }
        .activity-title {
            display: flex; align-items: center; gap: 7px;
            font-size: 14px; font-weight: 700;
        }
        .btn-see-all {
            font-size: 12px; font-weight: 600;
            color: var(--blue);
            background: none; border: none;
            cursor: pointer;
        }
        .btn-see-all:hover { text-decoration: underline; }

        .activity-list { display: flex; flex-direction: column; gap: 0; }
        .activity-item {
            display: flex; gap: 11px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            animation: fadeUp 0.3s ease both;
        }
        .activity-item:last-child { border-bottom: none; }

        .act-dot {
            width: 28px; height: 28px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            font-size: 11px; font-weight: 700;
            margin-top: 1px;
        }
        .act-dot.blue { background: var(--blue-soft); color: var(--blue); }
        .act-dot.red { background: #fef2f2; color: var(--red); }
        .act-dot.orange { background: var(--orange-soft); color: var(--orange); }
        .act-dot.green { background: var(--green-soft); color: var(--green); }
        .act-dot.purple { background: #f3e8ff; color: #7c3aed; }

        .act-body { flex: 1; }
        .act-text { font-size: 12.5px; font-weight: 500; line-height: 1.4; }
        .act-text a { color: var(--blue); font-weight: 600; text-decoration: none; }
        .act-text a:hover { text-decoration: underline; }
        .act-time { font-size: 11px; color: var(--muted); margin-top: 3px; }

        .activity-footer {
            margin-top: 14px;
            background: var(--bg);
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 12px; color: var(--muted);
            text-align: center;
            line-height: 1.5;
        }

        /* ── ANIMATIONS ── */
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 1024px) {
            .main { grid-template-columns: 1fr; }
            .right-col { position: static; }
        }
        @@media (max-width: 768px) {
            .sidebar { display: none; }
            .main { margin-left: 0; padding: 16px; }
            .info-grid { grid-template-columns: 1fr; }
            .profile-actions { flex-direction: column; }
            .quick-grid { grid-template-columns: repeat(2, 1fr); }
        }
            /* --- TRẠNG THÁI CHỈ XEM VÀ CHỈNH SỬA --- */
            .input-toggle {
                width: 100%;
                outline: none;
                transition: all 0.2s ease;
                font-family: var(--font);
            }

                /* Khi đang khóa (Readonly) -> Trông giống văn bản thường */
                .input-toggle[readonly] {
                    background-color: transparent !important;
                    border-color: transparent !important;
                    padding-left: 0 !important;
                    color: var(--text);
                    cursor: default;
                }

                /* Khi đang mở khóa (Cho phép sửa) -> Trông giống ô Input đang Focus */
                .input-toggle:not([readonly]) {
                    background-color: #fff !important;
                    border-color: var(--blue) !important;
                    box-shadow: 0 0 0 3px var(--blue-soft);
                    padding-left: 13px !important;
                }
    </style>
</head>
<body>

<!-- ═══════════════ SIDEBAR ═══════════════ -->
<aside class="sidebar">
    <div class="sidebar-logo">Admin</div>

    <div class="sidebar-profile">
        <div class="sidebar-avatar">
            <img src="https://i.pravatar.cc/80?img=11" alt="Admin"/>
        </div>
        <div>
            <div class="sidebar-profile-name">Admin Portal</div>
            <div class="sidebar-profile-role">Quản trị hệ thống</div>
        </div>
    </div>

    <nav class="sidebar-nav">
            <a href="@Url.Action("TongQuanAdmin", "TrangChuAd")" class="nav-item">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                Tổng quan
            </a>
            <a href="@Url.Action("Index", "NguoiDungAd")" class="nav-item">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                Quản lý người dùng
            </a>
            <a href="@Url.Action("Index", "ProfileAd")" class="nav-item active">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                My Profile
            </a>
            <a href="@Url.Action("Index", "ThongKeAd")" class="nav-item">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                </svg>
                Thống kê
            </a>
    </nav>

    <div class="sidebar-footer">

        <div class="nav-help">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            Help Center
        </div>
    </div>
</aside>

<!-- ═══════════════ MAIN ═══════════════ -->
<main class="main">

    <!-- LEFT COLUMN -->
    <div class="left-col">

        <!-- Profile Header -->
        <div class="profile-header-card">
                <div class="profile-avatar-wrap">
                    @{
                        var avatarUrl = string.IsNullOrEmpty(Model.AnhDaiDien)
                            ? $"https://ui-avatars.com/api/?name={Model.HoTen}&background=e8f0fe&color=1a56db&size=160"
                            : Model.AnhDaiDien;
                    }
                    <img src="@avatarUrl" alt="@Model.HoTen" />
                    <div class="avatar-badge">
                        <svg viewBox="0 0 24 24" fill="white">
                            <path d="M12 1l3.09 6.26L22 8.27l-5 4.87 1.18 6.88L12 16.77l-6.18 3.25L7 13.14 2 8.27l6.91-1.01L12 1z" />
                        </svg>
                    </div>
                </div>

                <div class="profile-info">
                    <div class="profile-name">@Model.HoTen</div>
                    <div class="profile-tags">
                        @if (Model.PhanQuyens != null && Model.PhanQuyens.Any())
                        {
                            foreach (var pq in Model.PhanQuyens)
                            {
                                <span class="badge-role">@pq.Quyen.TenQuyen</span>
                            }
                        }
                        else
                        {
                            <span class="badge-role" style="background:#64748b;">Chưa có quyền</span>
                        }

                        <span class="badge-status">
                            <span class="status-dot"></span>
                            @(Model.TrangThaiKhoa == true ? "Đang khóa" : "Đang hoạt động")
                        </span>
                    </div>
                </div>

            <div class="profile-actions">
                    <button type="button" class="btn-outline" id="btnEditProfile" onclick="enableEditMode()">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                        Cập nhật thông tin
                    </button>
                    <button type="button" class="btn-solid" onclick="openPasswordModal()">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        Quản lý bảo mật
                    </button>
            </div>
        </div>

        <!-- Thông tin tài khoản -->
            <form id="profileForm" asp-action="CapNhat" asp-controller="ProfileAd" method="post">
                @Html.AntiForgeryToken()
                <div class="card">
                    <div class="card-title">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        Thông tin tài khoản
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div style="background: var(--green-soft); color: var(--green); padding: 12px; border-radius: 8px; margin-bottom: 16px; font-size: 13.5px; font-weight: 600;">
                            @TempData["Success"]
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div style="background: #fef2f2; color: var(--red); padding: 12px; border-radius: 8px; margin-bottom: 16px; font-size: 13.5px; font-weight: 600;">
                            @TempData["Error"]
                        </div>
                    }

                    <div class="info-grid">
                        <div class="info-field">
                            <label>Họ và Tên</label>
                            <input type="text" id="inpHoTen" asp-for="HoTen" value="@Model.HoTen" class="info-value input-toggle" readonly />
                        </div>

                        <div class="info-field">
                            <label>Email công việc</label>
                            <div class="info-value" style="background: #f3f4f6; cursor: not-allowed; border-color: transparent;" title="Email đăng nhập không thể thay đổi">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                    <polyline points="22,6 12,13 2,6" />
                                </svg>
                                <span>@Model.Email</span>
                            </div>
                        </div>

                        <div class="info-field">
                            <label>Số điện thoại</label>
                            <input type="text" id="inpSdt" asp-for="SoDienThoai" value="@Model.SoDienThoai" class="info-value input-toggle" readonly />
                        </div>

                        <div class="info-field">
                            <label>Vị trí truy cập</label>
                            <div class="info-value" style="background: transparent; border-color: transparent; padding-left: 0;">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                                    <circle cx="12" cy="10" r="3" />
                                </svg>
                                <span>Đà Nẵng, Việt Nam</span>
                            </div>
                        </div>
                    </div>

                    <div id="editActionButtons" style="display: none; margin-top: 20px; justify-content: flex-end; gap: 10px;">
                        <button type="button" class="btn-outline" onclick="disableEditMode()">Hủy</button>
                        <button type="submit" class="btn-solid">
                            Lưu thay đổi
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Cài đặt bảo mật -->
        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Cài đặt bảo mật
            </div>

            <div class="security-item">
                <div class="sec-icon blue-soft">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="5" y="2" width="14" height="20" rx="2"/>
                        <line x1="12" y1="18" x2="12.01" y2="18"/>
                    </svg>
                </div>
                <div class="sec-body">
                    <div class="sec-title">Xác thực 2 yếu tố (2FA)</div>
                    <div class="sec-desc">Tăng cường bảo mật tài khoản bằng ứng dụng Authenticator.</div>
                </div>
                <div class="badge-active">
                    <svg width="10" height="10" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    ĐÃ KÍCH HOẠT
                </div>
            </div>

            <div class="security-item">
                <div class="sec-icon orange-soft">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
                        <line x1="18" y1="8" x2="23" y2="8"/><line x1="20.5" y1="5.5" x2="20.5" y2="10.5"/>
                    </svg>
                </div>
                <div class="sec-body">
                    <div class="sec-title">Mật khẩu định kỳ</div>
                    <div class="sec-desc">Lần thay đổi cuối: 3 tháng trước. Khuyến nghị cập nhật.</div>
                </div>
                <div class="security-item">
                    <button type="button" class="btn-link" onclick="openPasswordModal()">Thay đổi</button>
                </div>
            </div>
        </div>

        <!-- Quyền hạn truy cập -->
        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
                </svg>
                Quyền hạn truy cập
            </div>
            <div class="quick-grid">
                <a href="@Url.Action("Index", "NguoiDungAd")" style="text-decoration: none;">
                    <div class="quick-btn">
                        <div class="qicon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg></div>
                        Quản lý người dùng
                    </div>
                </a>

                <a href="@Url.Action("TongQuanAdmin", "TrangChuAd")" style="text-decoration: none;">
                    <div class="quick-btn">
                        <div class="qicon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg></div>
                        Tổng quan
                    </div>
                </a>

                <a href="@Url.Action("Index", "ThongKeAd")" style="text-decoration: none;">
                    <div class="quick-btn">
                        <div class="qicon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg></div>
                        Báo cáo thống kê
                    </div>
                </a>
            </div>
                
        </div>

    <!-- RIGHT COLUMN: Activity Log -->
<div class="right-col">
    <div class="activity-card">
        <div class="activity-header">
            <div class="activity-title">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Lưu ý dành cho Quản trị viên
            </div>
        </div>

        <div class="activity-list">
            <div class="activity-item">
                <div class="act-dot blue">01</div>
                <div class="act-body">
                    <div class="act-text">Bảo mật tài khoản</div>
                    <div class="act-time">Tuyệt đối không chia sẻ mật khẩu hoặc phiên đăng nhập cho bên thứ 3.</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="act-dot orange">02</div>
                <div class="act-body">
                    <div class="act-text">Phân quyền thận trọng</div>
                    <div class="act-time">Kiểm tra kỹ thông tin người dùng trước khi cấp quyền "Admin" hoặc "HDV".</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="act-dot red">03</div>
                <div class="act-body">
                    <div class="act-text">Khóa tài khoản vi phạm</div>
                    <div class="act-time">Khi phát hiện bất thường, hãy tạm khóa tài khoản thay vì xóa vĩnh viễn để giữ lại lịch sử.</div>
                </div>
            </div>
            <div class="activity-item">
                <div class="act-dot green">04</div>
                <div class="act-body">
                    <div class="act-text">Sao lưu hệ thống</div>
                    <div class="act-time">Hệ thống sẽ tự động xuất báo cáo tài chính vào ngày 01 hàng tháng.</div>
                </div>
            </div>
        </div>

        <div class="activity-footer">
            Mọi thao tác của bạn đều được<br />hệ thống ghi nhận để đảm bảo an toàn.
        </div>
    </div>
</div>
<div id="changePasswordModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#fff; width:450px; padding:25px; border-radius:12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);">
        <h3 style="margin-bottom: 18px; font-size: 18px; color: var(--text); display:flex; align-items:center; gap:8px;">
            <svg width="20" height="20" fill="none" stroke="var(--blue)" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            Đổi mật khẩu an toàn
        </h3>

        <form asp-action="DoiMatKhau" asp-controller="ProfileAd" method="post" id="formDoiMatKhau" onsubmit="return validatePassword()">
            @Html.AntiForgeryToken()
            <div style="margin-bottom: 15px;">
                <label style="display:block; font-size:13px; font-weight:600; margin-bottom:5px; color:var(--text-muted)">Mật khẩu hiện tại</label>
                <input type="password" name="MatKhauCu" required placeholder="Nhập mật khẩu đang dùng" style="width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:8px; outline:none; font-family:var(--font);" />
            </div>
            <div style="margin-bottom: 15px;">
                <label style="display:block; font-size:13px; font-weight:600; margin-bottom:5px; color:var(--text-muted)">Mật khẩu mới</label>
                <input type="password" name="MatKhauMoi" id="MatKhauMoi" required placeholder="Nhập mật khẩu mới" style="width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:8px; outline:none; font-family:var(--font);" />
            </div>
            <div style="margin-bottom: 24px;">
                <label style="display:block; font-size:13px; font-weight:600; margin-bottom:5px; color:var(--text-muted)">Xác nhận mật khẩu mới</label>
                <input type="password" name="XacNhanMatKhau" id="XacNhanMatKhau" required placeholder="Nhập lại mật khẩu mới" style="width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:8px; outline:none; font-family:var(--font);" />
                <span id="pwdError" style="color:var(--red); font-size:12px; display:none; margin-top:6px; font-weight:500;">Mật khẩu xác nhận không khớp!</span>
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" onclick="closePasswordModal()" style="padding:9px 16px; border:1px solid var(--border); background:#fff; border-radius:8px; cursor:pointer; font-weight:600; color:var(--text)">Hủy</button>
                <button type="submit" class="btn-solid" style="padding:9px 16px;">Lưu mật khẩu</button>
            </div>
        </form>
    </div>
</div>
</main>
<script>
        // Hàm BẬT chế độ chỉnh sửa
        function enableEditMode() {
            // 1. Mở khóa ô nhập liệu
            document.getElementById('inpHoTen').removeAttribute('readonly');
            document.getElementById('inpSdt').removeAttribute('readonly');

            // 2. Ẩn nút "Cập nhật thông tin" trên cùng
            document.getElementById('btnEditProfile').style.display = 'none';

            // 3. Hiện nút "Lưu" và "Hủy"
            document.getElementById('editActionButtons').style.display = 'flex';

            // 4. Tự động trỏ chuột vào ô Họ Tên cho người dùng gõ luôn
            document.getElementById('inpHoTen').focus();
        }

        // Hàm TẮT chế độ chỉnh sửa (khi bấm Hủy)
        function disableEditMode() {
            // 1. Khóa lại ô nhập liệu
            document.getElementById('inpHoTen').setAttribute('readonly', 'true');
            document.getElementById('inpSdt').setAttribute('readonly', 'true');

            // 2. Khôi phục lại dữ liệu ban đầu (lỡ người dùng gõ bậy rồi bấm Hủy)
            document.getElementById('profileForm').reset();

            // 3. Ẩn nút "Lưu" & "Hủy"
            document.getElementById('editActionButtons').style.display = 'none';

            // 4. Hiện lại nút "Cập nhật thông tin"
            document.getElementById('btnEditProfile').style.display = 'flex';
        }
                // Mở modal đổi mật khẩu
        function openPasswordModal() {
            document.getElementById('changePasswordModal').style.display = 'flex';
        }

        // Đóng modal và xóa trắng dữ liệu đã nhập lỡ dở
        function closePasswordModal() {
            document.getElementById('changePasswordModal').style.display = 'none';
            document.getElementById('formDoiMatKhau').reset();
            document.getElementById('pwdError').style.display = 'none'; // Ẩn dòng báo lỗi
        }

        // Kiểm tra mật khẩu mới và xác nhận có giống nhau không trước khi gửi lên Server
        function validatePassword() {
            var pass = document.getElementById('MatKhauMoi').value;
            var confirmPass = document.getElementById('XacNhanMatKhau').value;

            if (pass !== confirmPass) {
                document.getElementById('pwdError').style.display = 'block';
                return false; // Chặn không cho form submit
            }
            return true; // Cho phép submit
        }
</script>
</body>
</html>
