<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
    // Current date
    const now = new Date();
    document.getElementById('currentDateLabel').textContent =
        now.toLocaleDateString('vi-VN', { day: '2-digit', month: 'long', year: 'numeric' });

    // Filter pills
    function setFilter(btn, period) {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter();
    }

    function applyFilter() {
        // In production: call AJAX to reload chart data
        // For demo, re-render with random variance
        updateRevenueData();
    }

    // Revenue / Booking chart
    const months = ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'];
    const revenueData  = [18, 22, 19, 38, 52, 48, 61, 55, 42, 47, 39, 58];
    const bookingData  = [120, 145, 138, 210, 280, 265, 310, 295, 248, 270, 230, 320];
    const targetData   = [25, 25, 25, 45, 55, 55, 65, 60, 45, 50, 45, 60];

    let currentMode = 'revenue';
    let revenueChart;

    function buildRevenueChart() {
        const ctx = document.getElementById('revenueChart').getContext('2d');
        revenueChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: months,
                datasets: [
                    {
                        label: 'Doanh thu (triệu ₫)',
                        data: revenueData,
                        backgroundColor: 'rgba(59,130,246,0.18)',
                        borderColor: '#3b82f6',
                        borderWidth: 2,
                        borderRadius: 6,
                        order: 2,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Mục tiêu',
                        data: targetData,
                        type: 'line',
                        borderColor: '#10b981',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        pointRadius: 0,
                        fill: false,
                        tension: 0.4,
                        order: 1,
                        yAxisID: 'y'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1a2340',
                        titleFont: { family: 'Be Vietnam Pro', size: 12 },
                        bodyFont: { family: 'Be Vietnam Pro', size: 12 },
                        padding: 10,
                        callbacks: {
                            label: ctx => ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString('vi-VN') + (currentMode === 'revenue' ? 'M ₫' : ' booking')
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: 'Be Vietnam Pro', size: 11 }, color: '#9ca3af' }
                    },
                    y: {
                        grid: { color: 'rgba(0,0,0,0.05)', drawBorder: false },
                        ticks: {
                            font: { family: 'Be Vietnam Pro', size: 11 },
                            color: '#9ca3af',
                            callback: v => (currentMode === 'revenue' ? v + 'M' : v)
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    function switchRevenueChart(btn, mode) {
        document.querySelectorAll('.chart-toggle button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentMode = mode;
        if (mode === 'booking') {
            revenueChart.data.datasets[0].data = bookingData;
            revenueChart.data.datasets[0].label = 'Số booking';
            revenueChart.data.datasets[1].data = bookingData.map(v => Math.round(v * 1.1));
        } else {
            revenueChart.data.datasets[0].data = revenueData;
            revenueChart.data.datasets[0].label = 'Doanh thu (triệu ₫)';
            revenueChart.data.datasets[1].data = targetData;
        }
        revenueChart.update();
    }

    function updateRevenueData() {
        if (!revenueChart) return;
        const variance = revenueChart.data.datasets[0].data.map(v => Math.max(5, v + Math.floor(Math.random() * 10 - 5)));
        revenueChart.data.datasets[0].data = variance;
        revenueChart.update();
    }

    buildRevenueChart();

    // Status donut
    const donutCtx = document.getElementById('statusDonut').getContext('2d');
    new Chart(donutCtx, {
        type: 'doughnut',
        data: {
            labels: ['Đã xác nhận', 'Hoàn thành', 'Chờ xử lý', 'Đã hủy'],
            datasets: [{
                data: [1842, 1450, 340, 218],
                backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ef4444'],
                borderWidth: 0,
                hoverOffset: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '68%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1a2340',
                    titleFont: { family: 'Be Vietnam Pro', size: 12 },
                    bodyFont: { family: 'Be Vietnam Pro', size: 12 },
                    padding: 10
                }
            }
        }
    });
</script>
