@model HeThongDatLich.Models.ThongKeViewModel
@{
    ViewData["Title"] = "Thống kê";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@{
    Layout = null;
}
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Be Vietnam Pro', sans-serif; box-sizing: border-box; }

    .tk-wrapper {
        padding: 28px 32px;
        background: #f4f6fb;
        min-height: 100vh;
    }

    /* ── Header ── */
    .tk-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .tk-header h1 {
        font-size: 22px;
        font-weight: 700;
        color: #1a2340;
        margin: 0;
    }
    .tk-header p {
        font-size: 13px;
        color: #7a8aad;
        margin: 4px 0 0;
    }
    .tk-header-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .tk-date-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #fff;
        border: 1px solid #e2e8f4;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        color: #4a5568;
        font-weight: 500;
    }
    .tk-date-badge i { color: #3b82f6; font-size: 15px; }
    .btn-export {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #1d4ed8;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background .2s;
    }
    .btn-export:hover { background: #1e40af; color: #fff; text-decoration: none; }
    .btn-export i { font-size: 15px; }

    /* ── Filter bar ── */
    .tk-filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }
    .filter-label {
        font-size: 13px;
        font-weight: 600;
        color: #4a5568;
    }
    .filter-btn {
        padding: 7px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        border: 1.5px solid #e2e8f4;
        background: #fff;
        color: #7a8aad;
        cursor: pointer;
        transition: all .2s;
    }
    .filter-btn.active, .filter-btn:hover {
        background: #1d4ed8;
        border-color: #1d4ed8;
        color: #fff;
    }
    .filter-select {
        padding: 7px 14px;
        border-radius: 8px;
        border: 1.5px solid #e2e8f4;
        background: #fff;
        font-size: 13px;
        color: #4a5568;
        font-family: 'Be Vietnam Pro', sans-serif;
        font-weight: 500;
        cursor: pointer;
        outline: none;
    }
    .filter-select:focus { border-color: #3b82f6; }

    /* ── KPI cards ── */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }
    .kpi-card {
        background: #fff;
        border-radius: 14px;
        padding: 20px 22px;
        border: 1px solid #e8edf6;
        position: relative;
        overflow: hidden;
        transition: box-shadow .2s, transform .15s;
    }
    .kpi-card:hover { box-shadow: 0 6px 24px rgba(30,64,175,.08); transform: translateY(-2px); }
    .kpi-card-icon {
        width: 42px; height: 42px;
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        margin-bottom: 14px;
    }
    .kpi-card-icon.blue   { background: #eff6ff; color: #2563eb; }
    .kpi-card-icon.green  { background: #f0fdf4; color: #16a34a; }
    .kpi-card-icon.amber  { background: #fffbeb; color: #d97706; }
    .kpi-card-icon.purple { background: #f5f3ff; color: #7c3aed; }
    .kpi-card-icon.coral  { background: #fff1f0; color: #e53e3e; }
    .kpi-card-label {
        font-size: 12px;
        color: #7a8aad;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .6px;
        margin-bottom: 6px;
    }
    .kpi-card-value {
        font-size: 26px;
        font-weight: 700;
        color: #1a2340;
        line-height: 1.1;
        margin-bottom: 8px;
    }
    .kpi-card-trend {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        font-weight: 600;
        border-radius: 20px;
        padding: 3px 9px;
    }
    .trend-up   { background: #f0fdf4; color: #16a34a; }
    .trend-down { background: #fff1f0; color: #e53e3e; }
    .kpi-card-sub { font-size: 11px; color: #aab0c0; margin-top: 4px; }

    /* ── Two-column chart row ── */
    .chart-row {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 16px;
        margin-bottom: 20px;
    }
    @@media (max-width: 1100px) {
        .chart-row { grid-template-columns: 1fr; }
    }

    /* ── Chart cards ── */
    .chart-card {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8edf6;
        padding: 22px 24px 18px;
    }
    .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }
    .chart-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #1a2340;
        margin: 0;
    }
    .chart-card-sub {
        font-size: 12px;
        color: #7a8aad;
        margin: 2px 0 0;
    }
    .chart-toggle {
        display: flex;
        background: #f0f4ff;
        border-radius: 8px;
        padding: 3px;
        gap: 2px;
    }
    .chart-toggle button {
        padding: 5px 12px;
        border: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        color: #7a8aad;
        background: transparent;
        transition: all .2s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }
    .chart-toggle button.active { background: #1d4ed8; color: #fff; }

    /* ── Bottom row ── */
    .bottom-row {
        display: grid;
        grid-template-columns: 1fr 1fr 340px;
        gap: 16px;
    }
    @@media (max-width: 1200px) {
        .bottom-row { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 860px) {
        .bottom-row { grid-template-columns: 1fr; }
    }

    /* ── Top tour table ── */
    .top-list { list-style: none; padding: 0; margin: 0; }
    .top-list li {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5fb;
    }
    .top-list li:last-child { border-bottom: none; }
    .rank-badge {
        width: 24px; height: 24px;
        border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }
    .rank-1 { background: #fef9c3; color: #b45309; }
    .rank-2 { background: #f1f5f9; color: #475569; }
    .rank-3 { background: #fff7ed; color: #c2410c; }
    .rank-n { background: #f4f6fb; color: #9ca3af; }
    .top-name { flex: 1; font-size: 13px; font-weight: 500; color: #2d3748; line-height: 1.4; }
    .top-booking { font-size: 12px; color: #7a8aad; }
    .top-revenue { font-size: 13px; font-weight: 700; color: #1d4ed8; white-space: nowrap; }

    /* ── Booking status donut ── */
    .status-list { list-style: none; padding: 0; margin: 16px 0 0; }
    .status-list li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5fb;
        font-size: 13px;
    }
    .status-list li:last-child { border-bottom: none; }
    .status-dot {
        width: 9px; height: 9px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
        flex-shrink: 0;
    }
    .status-name { color: #4a5568; display: flex; align-items: center; }
    .status-count { font-weight: 700; color: #1a2340; }
    .status-pct { font-size: 11px; color: #9ca3af; margin-left: 6px; }

    /* ── Activity feed ── */
    .activity-list { list-style: none; padding: 0; margin: 0; }
    .activity-list li {
        display: flex;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5fb;
    }
    .activity-list li:last-child { border-bottom: none; }
    .act-icon {
        width: 34px; height: 34px;
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }
    .act-icon.blue   { background: #eff6ff; color: #2563eb; }
    .act-icon.green  { background: #f0fdf4; color: #16a34a; }
    .act-icon.amber  { background: #fffbeb; color: #d97706; }
    .act-icon.red    { background: #fff1f0; color: #e53e3e; }
    .act-content { flex: 1; }
    .act-text { font-size: 13px; color: #2d3748; font-weight: 500; margin-bottom: 2px; }
    .act-text span { color: #1d4ed8; }
    .act-time { font-size: 11px; color: #9ca3af; }

    /* ── HDV performance ── */
    .hdv-row {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid #f1f5fb;
    }
    .hdv-row:last-child { border-bottom: none; }
    .hdv-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        background: #eff6ff; color: #2563eb;
        display: flex; align-items: center; justify-content: center;
        font-size: 13px; font-weight: 700; flex-shrink: 0;
    }
    .hdv-name { font-size: 13px; font-weight: 600; color: #1a2340; }
    .hdv-meta { font-size: 11px; color: #7a8aad; }
    .hdv-stat { margin-left: auto; text-align: right; }
    .hdv-tours { font-size: 13px; font-weight: 700; color: #1d4ed8; }
    .hdv-rating { font-size: 11px; color: #f59e0b; }
    .hdv-bar-wrap { width: 100%; background: #f0f4ff; border-radius: 4px; height: 5px; margin-top: 4px; }
    .hdv-bar { height: 5px; border-radius: 4px; background: #3b82f6; }

    /* ── Scrollable containers ── */
    .scroll-list { max-height: 280px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #e2e8f4 transparent; }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #6b7280; /* Màu xám xám nhẹ */
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 15px; /* Khoảng cách với tiêu đề */
        transition: color 0.2s;
    }

        .btn-back:hover {
            color: #1a56db; /* Màu xanh chủ đạo của bạn khi di chuột vào */
        }

    /* Tinh chỉnh tiêu đề để khớp */
    .page-header {
        margin-bottom: 25px;
    }
</style>

<div class="tk-wrapper">

    <!-- Header -->
    <a asp-controller="TrangChuAd" asp-action="TongQuanAdmin" class="btn-back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Quay lại
    </a>
    <div class="tk-header">
        <div>
            <h1>📊 Thống kê hệ thống</h1>
            <p>Tổng hợp dữ liệu hoạt động, doanh thu và hiệu suất toàn hệ thống.</p>
        </div>
        <div class="tk-header-right">
            <div class="tk-date-badge">
                <i class="ti ti-calendar"></i>
                <span id="currentDateLabel"></span>
            </div>
            <a href="/TrangChuAd/TaiBaoCaoPdf" class="btn-export">
                <i class="ti ti-download"></i> Xuất báo cáo PDF
            </a>
            <form asp-action="XuatCSV" asp-controller="ThongKeAd" method="post" style="display:inline;">
                <button type="submit" class="btn-export" style="background: #059669;">
                    <i class="ti ti-table"></i> Xuất CSV
                </button>
            </form>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="tk-filter-bar">
        <span class="filter-label">Khoảng thời gian:</span>
        <button class="filter-btn" onclick="setFilter(this,'7ngay')">7 ngày</button>
        <button class="filter-btn active" onclick="setFilter(this,'thang')">Tháng này</button>
        <button class="filter-btn" onclick="setFilter(this,'quy')">Quý này</button>
        <button class="filter-btn" onclick="setFilter(this,'nam')">Năm nay</button>
        <select class="filter-select" id="yearSelect" onchange="applyFilter()">
            <option value="2026">Năm 2026</option>
            <option value="2025">Năm 2025</option>
            <option value="2024">Năm 2024</option>
        </select>
    </div>

    <!-- KPI cards -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-card-icon blue"><i class="ti ti-ticket"></i></div>
            <div class="kpi-card-label">Tổng booking</div>
            <div class="kpi-card-value">@(Model?.TongBooking.ToString("N0") ?? "3,850")</div>
            <span class="kpi-card-trend trend-up"><i class="ti ti-trending-up" style="font-size:13px"></i>+12.4%</span>
            <div class="kpi-card-sub">So với tháng trước</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-card-icon green"><i class="ti ti-currency-dollar"></i></div>
            <div class="kpi-card-label">Doanh thu</div>
            <div class="kpi-card-value">@(Model?.TongDoanhThu.ToString("N0") ?? "84,200")<span style="font-size:14px;font-weight:500;color:#7a8aad"> ₫</span></div>
            <span class="kpi-card-trend trend-up"><i class="ti ti-trending-up" style="font-size:13px"></i>+18%</span>
            <div class="kpi-card-sub">Đã thanh toán</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-card-icon purple"><i class="ti ti-users"></i></div>
            <div class="kpi-card-label">Người dùng mới</div>
            <div class="kpi-card-value">@(Model?.TongNguoiDung.ToString("N0") ?? "126")</div>
            <span class="kpi-card-trend trend-up"><i class="ti ti-trending-up" style="font-size:13px"></i>+5.1%</span>
            <div class="kpi-card-sub">Tháng này</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-card-icon amber"><i class="ti ti-map-pin"></i></div>
            <div class="kpi-card-label">Tour đang chạy</div>
            <div class="kpi-card-value">47</div>
            <span class="kpi-card-trend trend-up"><i class="ti ti-trending-up" style="font-size:13px"></i>+3</span>
            <div class="kpi-card-sub">So với tuần trước</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-card-icon coral"><i class="ti ti-star"></i></div>
            <div class="kpi-card-label">Đánh giá TB</div>
            <div class="kpi-card-value">4.7<span style="font-size:14px;color:#7a8aad">/5</span></div>
            <span class="kpi-card-trend trend-down"><i class="ti ti-trending-down" style="font-size:13px"></i>-0.1</span>
            <div class="kpi-card-sub">1,240 lượt đánh giá</div>
        </div>
    </div>

    <!-- Chart row: revenue line + booking status donut -->
    <div class="chart-row">

        <!-- Revenue chart -->
        <div class="chart-card">
            <div class="chart-card-header">
                <div>
                    <div class="chart-card-title">Xu hướng doanh thu & booking</div>
                    <div class="chart-card-sub">Theo tháng trong năm hiện tại</div>
                </div>
                <div class="chart-toggle">
                    <button class="active" onclick="switchRevenueChart(this,'revenue')">Doanh thu</button>
                    <button onclick="switchRevenueChart(this,'booking')">Booking</button>
                </div>
            </div>
            <div style="position:relative;height:240px;">
                <canvas id="revenueChart" role="img" aria-label="Biểu đồ doanh thu theo tháng">Dữ liệu doanh thu 12 tháng.</canvas>
            </div>
            <!-- custom legend -->
            <div style="display:flex;gap:16px;margin-top:10px;font-size:12px;color:#7a8aad;">
                <span style="display:flex;align-items:center;gap:5px;"><span style="width:10px;height:10px;border-radius:2px;background:#3b82f6;"></span>Doanh thu (triệu ₫)</span>
                <span style="display:flex;align-items:center;gap:5px;"><span style="width:10px;height:4px;border-radius:2px;background:#10b981;display:inline-block;border-top:2px dashed #10b981;"></span>Mục tiêu</span>
            </div>
        </div>

        <!-- Booking status donut -->
        <div class="chart-card">
            <div class="chart-card-header">
                <div>
                    <div class="chart-card-title">Trạng thái đơn</div>
                    <div class="chart-card-sub">Phân bổ trạng thái booking</div>
                </div>
            </div>
            <div style="position:relative;height:180px;display:flex;align-items:center;justify-content:center;">
                <canvas id="statusDonut" role="img" aria-label="Biểu đồ trạng thái đơn đặt lịch">Phân bổ trạng thái booking.</canvas>
            </div>
            <ul class="status-list">
                <li>
                    <span class="status-name"><span class="status-dot" style="background:#3b82f6;"></span>Đã xác nhận</span>
                    <span><span class="status-count">1,842</span><span class="status-pct">47.8%</span></span>
                </li>
                <li>
                    <span class="status-name"><span class="status-dot" style="background:#10b981;"></span>Hoàn thành</span>
                    <span><span class="status-count">1,450</span><span class="status-pct">37.7%</span></span>
                </li>
                <li>
                    <span class="status-name"><span class="status-dot" style="background:#f59e0b;"></span>Chờ xử lý</span>
                    <span><span class="status-count">340</span><span class="status-pct">8.8%</span></span>
                </li>
                <li>
                    <span class="status-name"><span class="status-dot" style="background:#ef4444;"></span>Đã hủy</span>
                    <span><span class="status-count">218</span><span class="status-pct">5.7%</span></span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Bottom row -->
    <div class="bottom-row">

        <!-- Top tours -->
        <div class="chart-card">
            <div class="chart-card-header">
                <div>
                    <div class="chart-card-title">Top tour được đặt nhiều nhất</div>
                    <div class="chart-card-sub">Dựa theo doanh thu tháng này</div>
                </div>
            </div>
            <div class="scroll-list">
                <ul class="top-list">
                    <li>
                        <span class="rank-badge rank-1">1</span>
                        <div class="top-name">Tour Đà Nẵng – Hội An 3N2Đ</div>
                        <span class="top-booking">238 booking</span>
                        <span class="top-revenue">42.6M ₫</span>
                    </li>
                    <li>
                        <span class="rank-badge rank-2">2</span>
                        <div class="top-name">Tour Phú Quốc Luxury 4N3Đ</div>
                        <span class="top-booking">194 booking</span>
                        <span class="top-revenue">38.2M ₫</span>
                    </li>
                    <li>
                        <span class="rank-badge rank-3">3</span>
                        <div class="top-name">Tour Sapa Trekking Mùa Đông</div>
                        <span class="top-booking">176 booking</span>
                        <span class="top-revenue">29.7M ₫</span>
                    </li>
                    <li>
                        <span class="rank-badge rank-n">4</span>
                        <div class="top-name">Tour Nha Trang Biển Xanh 2N1Đ</div>
                        <span class="top-booking">151 booking</span>
                        <span class="top-revenue">21.4M ₫</span>
                    </li>
                    <li>
                        <span class="rank-badge rank-n">5</span>
                        <div class="top-name">Tour Hạ Long Bay Cruise 3N2Đ</div>
                        <span class="top-booking">138 booking</span>
                        <span class="top-revenue">19.8M ₫</span>
                    </li>
                    <li>
                        <span class="rank-badge rank-n">6</span>
                        <div class="top-name">Tour Đà Lạt Mộng Mơ 2N1Đ</div>
                        <span class="top-booking">121 booking</span>
                        <span class="top-revenue">16.2M ₫</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- HDV performance -->
        <div class="chart-card">
            <div class="chart-card-header">
                <div>
                    <div class="chart-card-title">Hiệu suất hướng dẫn viên</div>
                    <div class="chart-card-sub">Top HDV theo số tour dẫn</div>
                </div>
            </div>
            <div class="scroll-list">
                <div class="hdv-row">
                    <div class="hdv-avatar">NT</div>
                    <div style="flex:1;">
                        <div class="hdv-name">Nguyễn Thành</div>
                        <div class="hdv-meta">HDV quốc tế • Đà Nẵng</div>
                        <div class="hdv-bar-wrap"><div class="hdv-bar" style="width:88%"></div></div>
                    </div>
                    <div class="hdv-stat">
                        <div class="hdv-tours">22 tour</div>
                        <div class="hdv-rating">★ 4.9</div>
                    </div>
                </div>
