@model HeThongDatLich.Models.QuanLyNguoiDungViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý Người dùng – Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --sidebar-w: 220px;
            --bg: #f5f6fa;
            --sidebar-bg: #fff;
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-light: #eff6ff;
            --text: #1e293b;
            --text-muted: #64748b;
            --text-light: #94a3b8;
            --border: #e2e8f0;
            --card-bg: #fff;
            --radius: 14px;
            --shadow: 0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
            --font: 'Be Vietnam Pro', sans-serif;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
        }

        /* ── Sidebar ──────────────────────────────────────── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-brand .brand-name { font-size: 16px; font-weight: 800; color: var(--primary); letter-spacing: -.3px; }

        .sidebar-user {
            display: flex; align-items: center; gap: 10px;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
        }
        .avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 12px; font-weight: 700; flex-shrink: 0;
        }
        .sidebar-user .u-name { font-size: 13px; font-weight: 600; }
        .sidebar-user .u-role { font-size: 11px; color: var(--text-muted); }

        .sidebar-nav { flex: 1; padding: 10px 0; }

        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 20px; font-size: 13.5px; color: var(--text-muted);
            text-decoration: none; cursor: pointer;
            transition: background .15s, color .15s;
            position: relative;
        }
        .nav-item:hover { background: var(--primary-light); color: var(--primary); }
        .nav-item.active {
            background: var(--primary-light); color: var(--primary); font-weight: 600;
        }
        .nav-item.active::before {
            content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
            width: 3px; height: 22px; background: var(--primary); border-radius: 0 3px 3px 0;
        }
        .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; }

        .btn-create {
            margin: 0 16px 16px;
            background: var(--primary); color: #fff; border: none;
            border-radius: 10px; padding: 10px 16px;
            font-size: 13px; font-weight: 700; font-family: var(--font);
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 7px;
            transition: background .15s, transform .1s;
        }
        .btn-create:hover { background: var(--primary-dark); transform: translateY(-1px); }

        .sidebar-footer { padding: 12px 20px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 2px; }

        /* ── Main ─────────────────────────────────────────── */
        .main { margin-left: var(--sidebar-w); flex: 1; padding: 28px 32px; min-height: 100vh; }

        /* Page header */
        .page-header {
            display: flex; align-items: flex-start; justify-content: space-between;
            margin-bottom: 22px; gap: 20px;
        }
        .page-header h1 { font-size: 26px; font-weight: 800; color: var(--text); letter-spacing: -.5px; }
        .page-header p  { font-size: 13px; color: var(--text-muted); margin-top: 4px; line-height: 1.5; max-width: 280px; }

        .header-controls { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

        .search-box {
            display: flex; align-items: center; gap: 8px;
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 10px; padding: 9px 14px;
            width: 230px; transition: border-color .15s;
        }
        .search-box:focus-within { border-color: var(--primary); }
        .search-box input {
            border: none; outline: none; font-size: 13px; font-family: var(--font);
            color: var(--text); background: transparent; width: 100%;
        }
        .search-box input::placeholder { color: var(--text-light); }
        .search-box svg { color: var(--text-light); flex-shrink: 0; }

        .filter-select {
            display: flex; align-items: center; gap: 6px;
            background: var(--card-bg); border: 1.5px solid var(--border);
            border-radius: 10px; padding: 9px 14px;
            font-size: 13px; font-family: var(--font); color: var(--text);
            cursor: pointer; transition: border-color .15s;
        }
        .filter-select:focus-within { border-color: var(--primary); }
        .filter-select select {
            border: none; outline: none; background: transparent;
            font-family: var(--font); font-size: 13px; color: var(--text); cursor: pointer;
        }

        /* Stat cards */
        .stat-row {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 14px; margin-bottom: 20px;
        }
        .stat-card {
            background: var(--card-bg); border-radius: var(--radius);
            padding: 16px 20px; box-shadow: var(--shadow);
            display: flex; align-items: center; justify-content: space-between;
            transition: transform .2s;
        }
        .stat-card:hover { transform: translateY(-2px); }
        .stat-card .left .label {
            font-size: 10.5px; font-weight: 600; letter-spacing: .6px;
            text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;
        }
        .stat-card .left .value { font-size: 28px; font-weight: 800; color: var(--text); letter-spacing: -.5px; }
        .stat-card .left .value.green { color: #16a34a; }
        .stat-icon {
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
        }
        .stat-icon.blue  { background: #dbeafe; color: #2563eb; }
        .stat-icon.teal  { background: #ccfbf1; color: #0d9488; }
        .stat-icon.orange{ background: #ffedd5; color: #ea580c; }

        /* Table card */
        .table-card {
            background: var(--card-bg); border-radius: var(--radius);
            box-shadow: var(--shadow); margin-bottom: 20px; overflow: hidden;
        }
        table { width: 100%; border-collapse: collapse; }
        thead tr { border-bottom: 1.5px solid var(--border); }
        thead th {
            padding: 12px 18px; text-align: left; font-size: 12px;
            font-weight: 600; color: var(--text-muted); letter-spacing: .3px;
            white-space: nowrap;
        }
        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .12s;
        }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #fafbff; }
        tbody td { padding: 14px 18px; font-size: 13.5px; vertical-align: middle; }

        .user-cell { display: flex; align-items: center; gap: 11px; }
        .user-av {
            width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 700; color: #fff;
        }
        .user-av.c1 { background: linear-gradient(135deg,#f59e0b,#ef4444); }
        .user-av.c2 { background: linear-gradient(135deg,#06b6d4,#6366f1); }
        .user-av.c3 { background: linear-gradient(135deg,#64748b,#475569); }
        .user-av.c4 { background: linear-gradient(135deg,#8b5cf6,#ec4899); }

        .user-name  { font-size: 13.5px; font-weight: 600; color: var(--text); }
        .user-email { font-size: 12px; color: var(--text-muted); }

        .badge {
            display: inline-block; padding: 3px 10px; border-radius: 20px;
            font-size: 11.5px; font-weight: 600; white-space: nowrap;
        }
        .badge.hdv    { background: #dbeafe; color: #1d4ed8; }
        .badge.khach  { background: #dcfce7; color: #15803d; }
        .badge.admin  { background: #fee2e2; color: #b91c1c; }

                .badge.khachhang {
                    background: #f1f5f9;
                    color: #475569;
                }

        .status {
            display: flex; align-items: center; gap: 6px;
            font-size: 13px; font-weight: 500;
        }
        .status::before { content: ''; width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .status.active  { color: #16a34a; } .status.active::before  { background: #22c55e; }
        .status.locked  { color: #dc2626; } .status.locked::before  { background: #ef4444; }

        .action-btns { display: flex; align-items: center; gap: 6px; }
        .btn-action {
            width: 30px; height: 30px; border-radius: 8px; border: none;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: background .12s;
        }
        .btn-action.edit   { background: #eff6ff; color: #2563eb; }
        .btn-action.edit:hover   { background: #dbeafe; }
        .btn-action.lock   { background: #fef2f2; color: #dc2626; }
        .btn-action.lock:hover   { background: #fee2e2; }
        .btn-action.detail { background: #f8fafc; color: #64748b; }
        .btn-action.detail:hover { background: #f1f5f9; }

        /* Pagination */
        .table-footer {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 18px; border-top: 1px solid var(--border);
        }
        .table-footer p { font-size: 13px; color: var(--text-muted); }
        .pagination { display: flex; align-items: center; gap: 4px; }
        .pg-btn {
            width: 32px; height: 32px; border-radius: 8px; border: 1.5px solid var(--border);
            background: var(--card-bg); color: var(--text-muted); font-size: 13px;
            font-weight: 500; font-family: var(--font); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all .12s;
        }
        .pg-btn:hover { border-color: var(--primary); color: var(--primary); }
        .pg-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); font-weight: 700; }
        .pg-btn.arrow  { color: var(--text-muted); }

        /* Bottom row */
        .bottom-row { display: grid; grid-template-columns: 1fr 340px; gap: 16px; }

        .activity-card {
            background: var(--card-bg); border-radius: var(--radius);
            box-shadow: var(--shadow); padding: 20px 22px;
        }
        .act-title { font-size: 14px; font-weight: 700; margin-bottom: 16px; }

        .act-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid var(--border); }
        .act-item:last-child { border-bottom: none; }
        .act-ico {
            width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .act-ico.red    { background: #fee2e2; color: #dc2626; }
        .act-ico.purple { background: #f3e8ff; color: #9333ea; }
        .act-body { font-size: 13px; color: var(--text); line-height: 1.5; }
        .act-body strong { color: var(--text); }
        .act-time { font-size: 11.5px; color: var(--text-light); margin-top: 3px; }

        /* Report card */
        .report-card {
            background: linear-gradient(140deg, #1e3a8a 0%, #2563eb 100%);
            border-radius: var(--radius); padding: 22px 22px 20px;
            color: #fff; box-shadow: var(--shadow);
            position: relative; overflow: hidden;
        }
        .report-card::after {
            content: ''; position: absolute; right: -30px; bottom: -30px;
            width: 120px; height: 120px; border-radius: 50%;
            background: rgba(255,255,255,.05);
        }
        .report-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
        .report-card p  { font-size: 12.5px; opacity: .85; line-height: 1.5; margin-bottom: 18px; }

        .btn-report {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            background: rgba(255,255,255,.15); border: 1.5px solid rgba(255,255,255,.35);
            color: #fff; border-radius: 9px; padding: 9px 16px;
            font-size: 13px; font-weight: 600; font-family: var(--font);
            cursor: pointer; text-decoration: none; transition: background .15s;
            margin-bottom: 10px; width: 100%;
        }
        .btn-report:hover { background: rgba(255,255,255,.25); }
        .btn-report.outline {
            background: transparent; border: 1.5px solid rgba(255,255,255,.5);
        }
        .btn-report.outline:hover { background: rgba(255,255,255,.1); }

        svg { display: inline-block; vertical-align: middle; }
        /* ── Top Header Bar ───────────────────────────────── */
        .top-header {
            height: 60px;
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: flex-end; /* Đẩy các icon sang phải */
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .notif-icon {
            position: relative;
            cursor: pointer;
            color: var(--text-muted);
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<!-- ══ SIDEBAR ══════════════════════════════════════════════ -->
<aside class="sidebar">
        <a asp-controller="Home" asp-action="Index" style="text-decoration: none; color: inherit;">
            <div class="sidebar-brand">
                <div class="brand-name">Admin</div>
            </div>
        </a>

    <div class="sidebar-user">
        <div class="avatar">AP</div>
        <div>
            <div class="u-name">Admin Portal</div>
            <div class="u-role">Quản trị hệ thống</div>
        </div>
    </div>

    <nav class="sidebar-nav">
            @{
                string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            }
            <a class="nav-item @(controller == "TrangChuAd" && action == "TongQuanAdmin" ? "active" : "")"
               asp-controller="TrangChuAd" asp-action="TongQuanAdmin">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                Tổng quan
            </a>
            <a class="nav-item @(controller == "NguoiDungAd" ? "active" : "")"
               asp-controller="NguoiDungAd" asp-action="index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                Quản lý người dùng
            </a>

            <a class="nav-item @(controller == "ProfileAd" ? "active" : "")"
               asp-controller="ProfileAd" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                My Profile
            </a>

            <a class="nav-item @(controller == "ThongKeAd" ? "active" : "")"
               asp-controller="ThongKeAd"
               asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                </svg>
                Thống kê
            </a>


    </nav>


    <div class="sidebar-footer">
        <a class="nav-item" href="#" style="padding:8px 0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Help Center
        </a>
        <a class="nav-item" href="@Url.Action("DangXuat", "TaiKhoan")" style="padding:8px 0;color:#ef4444">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Đăng xuất
        </a>
    </div>
</aside>

<!-- ══ MAIN ═════════════════════════════════════════════════ -->
<main class="main">

    <!-- Page header -->
    <div class="page-header">
        <div>
            <h1>Quản lý Người dùng</h1>
            <p>Theo dõi, chỉnh sửa và quản lý quyền truy cập của thành viên.</p>
        </div>
        <div class="header-controls">
            <div class="search-box">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" placeholder="Tìm kiếm tên, email..." id="searchInput" oninput="filterTable()" />
            </div>
            <div class="filter-select">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
                    <select id="roleFilter" onchange="filterTable()">
                        <option value="">Tất cả vai trò</option>
                        <option value="HDV">Hướng dẫn viên</option>
                        <option value="KhachHang">Khách hàng</option>
                        <option value="Admin">Admin</option>
                    </select>
            </div>
        </div>
    </div>

    <!-- Stat cards -->
    <div class="stat-row">
        <div class="stat-card">
            <div class="left">
                <div class="label">Tổng người dùng</div>
                <div class="value">@Model.TongNguoiDung.ToString("N0")</div>
            </div>
            <div class="stat-icon blue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
        </div>
        <div class="stat-card">
            <div class="left">
                <div class="label">Hướng dẫn viên</div>
                <div class="value">@Model.TongHDV.ToString("N0")</div>
            </div>
            <div class="stat-icon teal">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
        </div>
        
    </div>

    <!-- User table -->
    <div class="table-card">
        <table id="userTable">
            <thead>
                <tr>
                    <th>Tên người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @{
                    var colorClasses = new[] { "c1", "c2", "c3", "c4" };
                    int idx = 0;
                }
                @foreach (var user in Model.DanhSachNguoiDung)
                {
                    var cc = colorClasses[idx % colorClasses.Length];
                    idx++;
                    var initial = user.HoTen?.Length > 0 ? user.HoTen.Substring(0, 1).ToUpper() : "?";
                        var badgeClass = user.TenQuyen == "HDV" ? "hdv" : (user.TenQuyen == "ADMIN" ? "admin" : "khach");
                        var badgeLabel = user.TenQuyen == "HDV" ? "Hướng Dẫn Viên" : (user.TenQuyen == "ADMIN" ? "Admin" : "Khách Hàng");
                        var statusClass = (user.TrangThaiKhoa == true) ? "locked" : "active";
                        var statusLabel = (user.TrangThaiKhoa == true) ? "Đang khóa" : "Hoạt động";
                        <tr data-name="@user.HoTen?.ToLower()"
                            data-email="@user.Email?.ToLower()"
                            data-role="@string.Join(",", user.PhanQuyens.Select(pq => pq.Quyen.TenQuyen))">
                        <td>
                            <div class="user-cell">
                                <div class="user-av @cc">@initial</div>
                                <div>
                                    <div class="user-name">@user.HoTen</div>
                                    <div class="user-email">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td style="color:var(--text-muted);font-size:13px;">@user.Email</td>
                            <!-- Thay thế đoạn badge cũ bằng đoạn này -->
                            <td>
                                @if (user.PhanQuyens != null && user.PhanQuyens.Any())
                                {
                                    @foreach (var pq in user.PhanQuyens)
                                    {
                                        <span class="badge @pq.Quyen.TenQuyen.ToLower()">@pq.Quyen.TenQuyen</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge" style="background:#f1f5f9; color:#64748b;">Chưa có quyền</span>
                                }
                            </td>
                        <td><span class="status @statusClass">@statusLabel</span></td>
                        <td>
                            <div class="action-btns">
                                    <button type="button" class="btn-action edit" 
                                        onclick="openModal(@user.MaNguoiDung, [@string.Join(",", user.PhanQuyens.Select(pq => pq.MaQuyen))])" 
                                        title="Chỉnh sửa quyền">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                    <form asp-action="KhoaTaiKhoan" asp-controller="NguoiDungAd"
                                          asp-route-id="@user.MaNguoiDung" method="post"
                                          style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn khóa/mở khóa tài khoản này?')">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn-action lock" title="Khóa/Mở khóa tài khoản">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                            </svg>
                                        </button>
                                    </form>
                                        <button type="button" class="btn-action edit" title="Chỉnh sửa thông tin & quyền"
                                                onclick="showFullEditModal(
                                            @user.MaNguoiDung,
                                            '@user.HoTen',
                                            '@user.Email',
                                            '@user.SoDienThoai',
                                            '@user.MatKhau',
                                            [@string.Join(",", user.PhanQuyens.Select(pq => pq.MaQuyen))]
                                             )">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <circle cx="11" cy="11" r="8"></circle>
                                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                            </svg>
                                        </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="pagination-container" style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding: 0 10px;">
    <div style="color: var(--text-muted); font-size: 14px;">
        Hiển thị trang @Model.TrangHienTai / @Model.TongSoTrang
    </div>
    <div class="pagination-buttons" style="display: flex; gap: 6px; align-items: center;">
        <button onclick="changePage(-1)" 
                class="page-btn" 
                style="padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; background: #fff; color: var(--text); font-size: 14px; cursor: pointer; @(Model.TrangHienTai <= 1 ? "opacity: 0.5; cursor: not-allowed;" : "")"
                @(Model.TrangHienTai <= 1 ? "disabled" : "")>
            Trước
        </button>

        @for (int i = 1; i <= Model.TongSoTrang; i++)
        {
            <button onclick="setPage(@i)" 
                    class="page-btn @(Model.TrangHienTai == i ? "active" : "")" 
                    style="padding: 8px 14px; border: 1px solid @(Model.TrangHienTai == i ? "var(--primary)" : "var(--border)"); border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; background-color: @(Model.TrangHienTai == i ? "var(--primary)" : "#fff"); color: @(Model.TrangHienTai == i ? "#fff" : "var(--text)");">
                @i
            </button>
        }

        <button onclick="changePage(1)" 
                class="page-btn" 
                style="padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; background: #fff; color: var(--text); font-size: 14px; cursor: pointer; @(Model.TrangHienTai >= Model.TongSoTrang ? "opacity: 0.5; cursor: not-allowed;" : "")"
                @(Model.TrangHienTai >= Model.TongSoTrang ? "disabled" : "")>
            Sau
        </button>
    </div>
</div>

    <!-- Bottom row -->
    <div class="bottom-row">

        <!-- Activity -->
        <div class="activity-card">
            <div class="act-title">Hoạt động hệ thống gần đây</div>
            @foreach (var act in Model.HoatDongGanDay)
            {
                var iconClass = act.LoaiHoatDong == "KhoaTaiKhoan" ? "red" : "purple";
                <div class="act-item">
                    <div class="act-ico @iconClass">
                        @if (act.LoaiHoatDong == "KhoaTaiKhoan")
                        {
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        }
                        else
                        {
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                        }
                    </div>
                    <div>
                        <div class="act-body">@Html.Raw(act.NoiDung)</div>
                        <div class="act-time">@act.ThoiGian</div>
                    </div>
                </div>
            }
        </div>

        <!-- Report card -->
        <div class="report-card">
            <h3>Báo cáo nhanh</h3>
            <p>Xuất danh sách người dùng và hướng dẫn viên định kỳ tháng này.</p>
            <a asp-action="XuatCSV" asp-controller="NguoiDungAd" class="btn-report">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Xuất file CSV
            </a>
            <a asp-action="GuiEmailThongBao" asp-controller="NguoiDungAd" class="btn-report outline">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
                Gửi Email Thông Báo
            </a>
        </div>
    </div>

    <div id="editRoleModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div style="background:#fff; width:400px; margin:100px auto; padding:20px; border-radius:10px;">
        <h3>Cập nhật quyền hạn</h3>
        <form asp-action="CapNhatQuyen" asp-controller="NguoiDungAd" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="maNguoiDung" id="modalMaNguoiDung" />
                     <div style="margin: 20px 0;">
                        <label>Chọn các quyền (có thể chọn nhiều):</label>
                        <div style="display:flex; flex-direction:column; gap:8px; margin-top:10px;">
                            <label><input type="checkbox" name="maQuyens" value="1"> Admin</label>
                            <label><input type="checkbox" name="maQuyens" value="2"> Khách hàng</label>
                            <label><input type="checkbox" name="maQuyens" value="3"> Hướng dẫn viên</label>
                        </div>
                    </div>
            
            <button type="submit" class="btn-create">Lưu thay đổi</button>
            <button type="button" onclick="closeModal()" style="background:#ccc; border:none; padding:8px 16px; border-radius:5px;">Hủy</button>
        </form>
    </div>
</div>

            <div id="editFullUserModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
                <div style="background:#fff; width:500px; margin:30px auto; padding:25px; border-radius:12px;">
                    <h3>Cập nhật tài khoản</h3>
                    <form asp-action="ChinhSuaToanDien" asp-controller="NguoiDungAd" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MaNguoiDung" id="editMaNguoiDung" />

                        <p><strong>Mã người dùng:</strong> <span id="displayMaNguoiDung"></span></p>

                        <div style="margin-top:15px;">
                            <label>Họ tên:</label>
                            <input type="text" name="HoTen" id="editHoTen" style="width:100%; padding:8px;" />
                        </div>

                        <div style="margin-top:10px;">
                            <label>Email:</label>
                            <input type="email" name="Email" id="editEmail" style="width:100%; padding:8px;" />
                        </div>

                        <div style="margin-top:10px;">
                            <label>Số điện thoại:</label>
                            <input type="text" name="SoDienThoai" id="editSdt" style="width:100%; padding:8px;" />
                        </div>

                        <div style="margin-top:10px;">
                            <label>Mật khẩu cũ:</label>
                            <input type="text" name="MatKhauCu" id="editMatKhauCu" readonly
                                   style="width:100%; padding:8px; background:#f8fafc; border:1px solid #ccc; border-radius:5px;" />
                        </div>
                        <div style="margin-top:10px;">
                            <label>Mật khẩu mới:</label>
                            <input type="password" name="MatKhauMoi" placeholder="Nhập mật khẩu mới..."
                                   autocomplete="new-password"
                                   style="width:100%; padding:8px; border:1px solid #ccc; border-radius:5px;" />
                        </div>

                        <div style="margin-top:10px;">
                            <label>Vai trò:</label><br />
                            <label><input type="checkbox" name="MaQuyens" value="1"> Admin</label>
                            <label><input type="checkbox" name="MaQuyens" value="2"> Khách hàng</label>
                            <label><input type="checkbox" name="MaQuyens" value="3"> HDV</label>
                        </div>

                        <button type="submit" style="margin-top:20px; width:100%; padding:10px; background:#2563eb; color:white; border:none; border-radius:5px;">Lưu toàn bộ</button>
                        <button type="button" onclick="closeEditModal()"
                                style="flex:1; padding:10px; background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; border-radius:8px; cursor:pointer;">
                            Hủy
                        </button>
                    </form>
                </div>
            </div>

</main>

<script>
    // ── 1. Live search + role filter (Lọc tạm trên giao diện trang hiện tại) ──
    function filterTable() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const role = document.getElementById('roleFilter').value; 
        const rows = document.querySelectorAll('#tableBody tr');

        rows.forEach(row => {
            const name = row.dataset.name || '';
            const email = row.dataset.email || '';
            // Lấy danh sách quyền từ data-role và chuyển thành mảng
            const roles = (row.dataset.role || '').split(',');

            const matchQ = !q || name.includes(q) || email.includes(q);

            // Kiểm tra nếu bộ lọc trống HOẶC vai trò chọn nằm trong danh sách quyền của người dùng
            const matchRole = !role || roles.includes(role);

            if (matchQ && matchRole) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    // ── 2. Pagination (Phân trang Server-side, sửa lỗi sập nền trắng) ──
    // Dùng Model? và bọc dấu nháy để đảm bảo JS không bao giờ bị lỗi cú pháp dù dữ liệu rỗng
    const currentSearchKeyword = '@Html.Raw(Model?.TuKhoaTimKiem ?? "")';
    const currentRoleFilter = '@Html.Raw(Model?.VaiTroLocHien ?? "")';
    const totalPagesCount = parseInt('@(Model?.TongSoTrang ?? 1)');
    const currentPageNum = parseInt('@(Model?.TrangHienTai ?? 1)');

    function setPage(n) {
        // Ngăn chặn bấm lố trang
        if (n < 1 || n > totalPagesCount) return;
        // Chuyển hướng trình duyệt gọi xuống Controller lấy dữ liệu trang mới
        window.location.href = `?trang=${n}&tuKhoa=${encodeURIComponent(currentSearchKeyword)}&vaiTro=${encodeURIComponent(currentRoleFilter)}`;
    }

    function changePage(dir) {
        const next = currentPageNum + dir;
        setPage(next);
    }

    // ── 3. Quản lý các Modals ──
    function openModal(id) {
        document.getElementById('modalMaNguoiDung').value = id;
        document.getElementById('editRoleModal').style.display = 'block';
    }

    function closeModal() {
        document.getElementById('editRoleModal').style.display = 'none';
    }

    function showFullEditModal(id, hoTen, email, sdt, matKhau, roleIds) {
        document.getElementById('editMaNguoiDung').value = id;
        document.getElementById('displayMaNguoiDung').innerText = id;
        document.getElementById('editHoTen').value = hoTen;
        document.getElementById('editEmail').value = email;
        document.getElementById('editSdt').value = sdt;
        document.getElementById('editMatKhauCu').value = matKhau || "";
        
        // Bọc an toàn: Xử lý trường hợp roleIds bị truyền vào từ HTML dạng chuỗi hoặc số
        let rolesArray = [];
        if (Array.isArray(roleIds)) {
            rolesArray = roleIds;
        } else if (typeof roleIds === 'string') {
            try { rolesArray = JSON.parse(roleIds); } catch(e) { rolesArray = []; }
        } else if (typeof roleIds === 'number') {
            rolesArray = [roleIds];
        }

        // Tự động tick checkbox
        const checkboxes = document.querySelectorAll('input[name="MaQuyens"]');
        checkboxes.forEach(cb => {
            cb.checked = rolesArray.includes(parseInt(cb.value));
        });
        
        document.getElementById('editFullUserModal').style.display = 'block';
    }               

    function closeEditModal() {
        document.getElementById('editFullUserModal').style.display = 'none';
    }
</script>
</body>
</html>
