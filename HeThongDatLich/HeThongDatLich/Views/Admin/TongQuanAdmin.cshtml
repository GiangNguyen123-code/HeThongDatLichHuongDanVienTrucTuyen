@model HeThongDatLich.Models.ThongKeAdminViewModel
@using HeThongDatLich.Extensions
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tổng quan hệ thống – Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        /* ── Reset & Variables ────────────────────────────── */
        *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        }

        :root {
        --sidebar-w: 220px;
        --bg: #f5f6fa;
        --sidebar-bg: #fff;
        --primary: #2563eb;
        --primary-dark: #1d4ed8;
        --primary-light: #eff6ff;
        --text: #1e293b;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --border: #e2e8f0;
        --card-bg: #fff;
        --green: #22c55e;
        --red: #ef4444;
        --orange: #f97316;
        --radius: 14px;
        --shadow: 0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
        --font: 'Be Vietnam Pro', sans-serif;
        }

        body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        display: flex;
        min-height: 100vh;
        }

        /* ── Sidebar ──────────────────────────────────────── */
        .sidebar {
        width: var(--sidebar-w);
        background: var(--sidebar-bg);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        }

        .sidebar-brand {
        padding: 22px 20px 18px;
        border-bottom: 1px solid var(--border);
        }

        .sidebar-brand .brand-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        }

        .sidebar-brand .brand-sub {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
        }

        .sidebar-user {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        }

        .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        flex-shrink: 0;
        }

        .sidebar-user .user-name {
        font-size: 13px;
        font-weight: 600;
        }

        .sidebar-user .user-role {
        font-size: 11px;
        color: var(--text-muted);
        }

        .sidebar-nav {
        flex: 1;
        padding: 10px 0;
        }

        .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        font-size: 13.5px;
        color: var(--text-muted);
        text-decoration: none;
        border-radius: 0;
        cursor: pointer;
        transition: background .15s, color .15s;
        position: relative;
        }

        .nav-item:hover {
        background: var(--primary-light);
        color: var(--primary);
        }

        .nav-item.active {
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 600;
        }

        .nav-item.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 22px;
        background: var(--primary);
        border-radius: 0 3px 3px 0;
        }

        .nav-item svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        }

        .sidebar-footer {
        padding: 14px 20px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 2px;
        }

        .btn-create {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 600;
        font-family: var(--font);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        margin: 0 20px 14px;
        transition: background .15s, transform .1s;
        }

        .btn-create:hover {
        background: var(--primary-dark);
        transform: translateY(-1px);
        }

        /* ── Main ─────────────────────────────────────────── */
        .main {
        margin-left: var(--sidebar-w);
        flex: 1;
        padding: 28px 32px;
        min-height: 100vh;
        }

        /* ── Top header ───────────────────────────────────── */
        .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 24px;
        }

        .page-header h1 {
        font-size: 22px;
        font-weight: 700;
        color: var(--text);
        }

        .page-header p {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 3px;
        }

        .header-right {
        display: flex;
        align-items: center;
        gap: 12px;
        }

        .date-badge {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 7px;
        }

        .date-badge svg {
        color: var(--primary);
        }

        /* ── Stat Cards ───────────────────────────────────── */
        .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 20px;
        }

        .stat-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 18px 20px;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        gap: 6px;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
        }

        .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }

        .stat-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        }

        .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .stat-icon.blue {
        background: #eff6ff;
        color: #2563eb;
        }

        .stat-icon.teal {
        background: #f0fdfa;
        color: #0d9488;
        }

        .stat-icon.red {
        background: #fef2f2;
        color: #ef4444;
        }

        .stat-icon.dark {
        background: #1e293b;
        color: #fff;
        }

        .stat-badge {
        font-size: 11.5px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 20px;
        }

        .stat-badge.up {
        background: #dcfce7;
        color: #16a34a;
        }

        .stat-badge.down {
        background: #fee2e2;
        color: #dc2626;
        }

        .stat-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
        }

        .stat-value {
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -.5px;
        }

        /* ── Middle row ───────────────────────────────────── */
        .mid-row {
        display: grid;
        grid-template-columns: 1fr 350px; /* Tăng nhẹ chiều rộng cột bên phải nếu cần */
        gap: 16px;
        margin-bottom: 20px;
        align-items: stretch; /* Đảm bảo các card cao bằng nhau */
        }

        .card {
        background: var(--card-bg);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 22px 22px 18px;
        }

        .card-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
        }

        .card-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        }

        .tab-group {
        display: flex;
        background: #f1f5f9;
        border-radius: 8px;
        padding: 3px;
        gap: 2px;
        }

        .tab-btn {
        padding: 5px 14px;
        font-size: 12.5px;
        font-weight: 500;
        border-radius: 6px;
        border: none;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font-family: var(--font);
        transition: background .15s, color .15s;
        }

        .tab-btn.active {
        background: var(--primary);
        color: #fff;
        }

        .chart-wrap {
        position: relative;
        height: 300px; /* Tăng chiều cao cơ sở lên một chút */
        width: 100%;
        }
        /* Activity feed */
        .activity-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        }

        .activity-link {
        font-size: 12px;
        color: var(--primary);
        font-weight: 500;
        text-decoration: none;
        }

        .activity-link:hover {
        text-decoration: underline;
        }

        .activity-item {
        display: flex;
        gap: 12px;
        padding: 11px 0;
        border-bottom: 1px solid var(--border);
        align-items: flex-start;
        }

        .activity-item:last-child {
        border-bottom: none;
        }

        .act-icon {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
        }

        .act-icon.green {
        background: #dcfce7;
        color: #16a34a;
        }

        .act-icon.blue {
        background: #dbeafe;
        color: #2563eb;
        }

        .act-icon.purple {
        background: #f3e8ff;
        color: #9333ea;
        }

        .act-icon.red {
        background: #fee2e2;
        color: #dc2626;
        }

        .act-text {
        font-size: 12.5px;
        color: var(--text);
        line-height: 1.45;
        }

        .act-time {
        font-size: 11px;
        color: var(--text-light);
        margin-top: 3px;
        }

        /* ── Bottom row ───────────────────────────────────── */
        .bottom-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        }

        .card-dark {
        background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
        color: #fff;
        border-radius: var(--radius);
        padding: 24px 24px 20px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
        }

        .card-dark::after {
        content: '';
        position: absolute;
        right: -40px;
        bottom: -40px;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(255,255,255,.06);
        }

        .card-dark::before {
        content: '';
        position: absolute;
        right: 30px;
        bottom: -20px;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
        }

        .card-dark h3 {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 8px;
        position: relative;
        }

        .card-dark p {
        font-size: 12.5px;
        opacity: .85;
        margin-bottom: 20px;
        position: relative;
        line-height: 1.5;
        }

        .btn-download {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,.15);
        border: 1.5px solid rgba(255,255,255,.4);
        color: #fff;
        border-radius: 9px;
        padding: 9px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: var(--font);
        cursor: pointer;
        transition: background .15s;
        text-decoration: none;
        position: relative;
        }

        .btn-download:hover {
        background: rgba(255,255,255,.25);
        }

        .pending-card {
        background: var(--card-bg);
        border-radius: var(--radius);
        padding: 22px 22px 20px;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        }

        .pending-top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        }

        .pending-avatars {
        display: flex;
        }

        .pending-avatars .av {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 2px solid #fff;
        margin-right: -8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        }

        .av1 {
        background: linear-gradient(135deg, #f97316, #ef4444);
        }

        .av2 {
        background: linear-gradient(135deg, #06b6d4, #2563eb);
        }

        .av3 {
        background: linear-gradient(135deg, #8b5cf6, #ec4899);
        }

        .av-count {
        background: #f1f5f9;
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 600;
        margin-right: 0 !important;
        }

        .pending-badge {
        background: #fef2f2;
        color: #dc2626;
        font-size: 12px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        }

        .pending-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        }

        .pending-desc {
        font-size: 12.5px;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 16px;
        }

        .btn-review {
        display: block;
        text-align: center;
        background: var(--primary-light);
        color: var(--primary);
        border: 1.5px solid #bfdbfe;
        border-radius: 9px;
        padding: 10px;
        font-size: 13px;
        font-weight: 600;
        font-family: var(--font);
        cursor: pointer;
        text-decoration: none;
        transition: background .15s;
        }

        .btn-review:hover {
        background: #dbeafe;
        }

        /* ── SVG Icons inline ─────────────────────────────── */
        svg {
        display: inline-block;
        vertical-align: middle;
        }
    </style>
</head>
<body>

    <!-- ══════════════════════════════════════════════
     SIDEBAR
══════════════════════════════════════════════ -->
    <aside class="sidebar">
        <a asp-controller="Home" asp-action="Index" style="text-decoration: none; color: inherit;">
            <div class="sidebar-brand">
                <div class="brand-name">Admin</div>
            </div>
        </a>

        <div class="sidebar-user">
            <div class="avatar">AP</div>
            <div>
                <div class="user-name">Admin Portal</div>
                <div class="user-role">Quản trị hệ thống</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            @{
                string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            }
            <a class="nav-item @(controller == "TrangChuAd" && action == "TongQuanAdmin" ? "active" : "")"
               asp-controller="TrangChuAd" asp-action="TongQuanAdmin">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                Tổng quan
            </a>
            <a class="nav-item @(controller == "NguoiDungAd" ? "active" : "")"
               asp-controller="NguoiDungAd" asp-action="index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                Quản lý người dùng
            </a>

            <a class="nav-item @(controller == "ProfileAd" ? "active" : "")" 
                asp-controller="ProfileAd" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                My Profile
            </a>

            <a class="nav-item @(controller == "ThongKeAd" ? "active" : "")"
               asp-controller="ThongKeAd"
               asp-action="Index">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                </svg>
                Thống kê
            </a>

        </nav>

        <div class="sidebar-footer">
            <a class="nav-item" href="#" style="padding:8px 0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                Help Center
            </a>
            <a class="nav-item" href="@Url.Action("DangXuat", "TaiKhoan")" style="padding:8px 0;color:#ef4444">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                Logout
            </a>
        </div>
    </aside>

    <!-- ══════════════════════════════════════════════
     MAIN CONTENT
══════════════════════════════════════════════ -->
    <main class="main">

        <!-- Page header -->
        <div class="page-header">
            <div>
                <h1>Tổng quan hệ thống</h1>
                <p>Chào mừng trở lại, Admin. Đây là những gì đang diễn ra hôm nay.</p>
            </div>
            <div class="header-right">
                <div class="date-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    @DateTime.Now.ToString("MMMM, yyyy", new System.Globalization.CultureInfo("vi-VN"))
                </div>
                <div class="avatar" style="width:38px;height:38px;font-size:14px;">AP</div>
            </div>
        </div>

        <!-- Stat cards -->
        <div class="stat-grid">
            <!-- Tổng người dùng -->
            <div class="stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon blue">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                    </div>
                    <span class="stat-badge up">+12%↑</span>
                </div>
                <div class="stat-label">Tổng người dùng</div>
                <div class="stat-value">@Model.TongNguoiDung.ToString("N0")</div>
            </div>

            <!-- Tổng HDV -->
            <div class="stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon teal">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></svg>
                    </div>
                    <span class="stat-badge up">+5%↑</span>
                </div>
                <div class="stat-label">Tổng HDV</div>
                <div class="stat-value">@Model.TongHDV.ToString("N0")</div>
            </div>

            <!-- Tổng Booking -->
            <div class="stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon red">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><rect x="8" y="2" width="8" height="4" rx="1" /></svg>
                    </div>
                    <span class="stat-badge down">-2%↓</span>
                </div>
                <div class="stat-label">Tổng Booking</div>
                <div class="stat-value">@Model.TongBooking.ToString("N0")</div>
            </div>

            <!-- Tổng Doanh thu -->
            <div class="stat-card">
                <div class="stat-card-header">
                    <div class="stat-icon dark">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                    </div>
                    <span class="stat-badge up">+18%↑</span>
                </div>
                <div class="stat-label">Tổng Doanh thu</div>
                <div class="stat-value">$@Model.TongDoanhThu.ToVnd()</div>
            </div>
        </div>

        <!-- Middle: Chart + Activity -->
        <div class="mid-row">
            <!-- Revenue Chart -->
            <div class="card">
                <div class="card-title-row">
                    <span class="card-title">Xu hướng doanh thu</span>
                    <div class="tab-group">
                        <button class="tab-btn active" onclick="switchTab(this,'month')">Theo tháng</button>
                        <button class="tab-btn" onclick="switchTab(this,'year')">Theo năm</button>
                    </div>
                </div>
                <div class="chart-wrap">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>

            <!-- Activity feed -->
            <div class="card">
                <div class="card-title-row">
                    <span class="card-title">Tình trạng hệ thống</span>
                </div>
                <div class="activity-list">
                    <div class="activity-item">
                        <div class="act-icon red">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </div>
                        <div class="act-text">
                            Có <strong>@Model.SoTaiKhoanKhoa tài khoản</strong> đang bị khóa.
                            <br /><a href="/admin/nguoi-dung" style="font-size:11px; color:var(--red);">Xem danh sách</a>
                        </div>
                    </div>
                    <div class="activity-item">
                        <div class="act-icon blue">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                        </div>
                        <div class="act-text">
                            Có <strong>@Model.SoTaiKhoanChuaCoQuyen tài khoản</strong> cần được phân quyền.
                            <br /><a href="/admin/nguoi-dung" style="font-size:11px; color:var(--primary);">Đi đến trang phân quyền</a>
                        </div>
                    </div>
                </div>
            </div>

    </main>

    <script>
        // ── Chart.js Revenue Bar+Line Chart ──────────────────
        const labels = ['T4','T5','T6','T7','T8','T9'];

        // Dữ liệu từ Model (Razor sẽ render mảng JS)
        const monthlyData = @Html.Raw(
                "[" + string.Join(",", Model.DoanhThuCacThang.Select(v => v.ToString(System.Globalization.CultureInfo.InvariantCulture))) + "]"
                );

        const ctx = document.getElementById('revenueChart').getContext('2d');

        const gradient = ctx.createLinearGradient(0, 0, 0, 220);
        gradient.addColorStop(0, 'rgba(37,99,235,0.15)');
        gradient.addColorStop(1, 'rgba(37,99,235,0)');

        const barColors = monthlyData.map((_, i) =>
        i === monthlyData.length - 1 ? '#2563eb' : '#bfdbfe'
        );

        const revenueChart = new Chart(ctx, {
        type: 'bar',
        data: {
        labels,
        datasets: [
        {
        type: 'bar',
        label: 'Doanh thu',
        data: monthlyData,
        backgroundColor: barColors,
        borderRadius: 6,
        borderSkipped: false,
        order: 2,
        },
        {
        type: 'line',
        label: 'Xu hướng',
        data: monthlyData,
        borderColor: '#93c5fd',
        borderWidth: 2,
        pointRadius: 0,
        tension: 0.4,
        fill: true,
        backgroundColor: gradient,
        order: 1,
        }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false },
        tooltip: {
        backgroundColor: '#1e293b',
        titleColor: '#94a3b8',
        bodyColor: '#fff',
        padding: 10,
        callbacks: {
        label: ctx => ' $' + ctx.parsed.y.toLocaleString()
        }
        }
        },
        scales: {
        x: {
        grid: { display: false },
        border: { display: false },
        ticks: { color: '#94a3b8', font: { size: 12, family: "'Be Vietnam Pro'" } }
        },
        y: {
        grid: { color: '#f1f5f9', drawBorder: false },
        border: { display: false, dash: [4,4] },
        ticks: {
        color: '#94a3b8',
        font: { size: 11, family: "'Be Vietnam Pro'" },
        callback: v => '$' + (v/1000).toFixed(0) + 'k'
        }
        }
        }
        }
        });

        // ── Tab switch ────────────────────────────────────────
        function switchTab(btn, mode) {
        btn.closest('.tab-group').querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        // You can swap chart data here based on mode
        }
    </script>
</body>
</html>
