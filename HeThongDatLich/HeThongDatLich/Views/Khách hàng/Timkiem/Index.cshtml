@model IEnumerable<HeThongDatLich.Models.HOSOHDV>
@{
    ViewData["Title"] = "Tìm kiếm Hướng dẫn viên";
}

<section class="hero" style="height: 380px; background: url('https://images.unsplash.com/photo-1528127269322-539801943592?w=1600&q=80') center/cover;">
    <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.35) 0%, rgba(0,0,0,.55) 100%);"></div>
    <h1 style="position: relative; z-index: 1; font-size: 34px; font-weight: 700; color: #fff;">Tìm hướng dẫn viên địa phương</h1>
</section>

<div class="content-wrap d-flex gap-4" style="max-width: 1100px; margin: 32px auto; padding: 0 24px;">
    <aside class="sidebar" style="width: 240px; flex-shrink: 0; background: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.06);">
        <form asp-action="Index" method="get">
            <h6 class="text-uppercase text-muted fw-bold mb-3">Bộ Lọc</h6>
            
            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size: 13px;">Khu vực (Tỉnh/Thành)</label>
                <select name="maTinh" class="form-select form-select-sm" asp-items="ViewBag.TinhThanhs">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size: 13px;">Ngôn ngữ</label>
                <select name="maNgonNgu" class="form-select form-select-sm" asp-items="ViewBag.NgonNgus">
                    <option value="">-- Tất cả --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" style="font-size: 13px;">Mức giá / ngày</label>
                <input type="number" name="giaTu" value="@ViewBag.GiaTu" class="form-control form-control-sm mb-2" placeholder="Từ giá..." />
                <input type="number" name="giaDen" value="@ViewBag.GiaDen" class="form-control form-control-sm" placeholder="Đến giá..." />
            </div>

            <button type="submit" class="btn w-100" style="background: #1557b0; color: white; font-size: 13px;">Áp dụng</button>
        </form>
    </aside>

    <div class="listing flex-grow-1">
        <h4 class="mb-4" style="font-weight: 700; color: #1a1a2e;">Kết quả tìm kiếm (@Model.Count() HDV)</h4>
        
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0" style="border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07);">
                        <div style="height: 160px; overflow: hidden;">
                            <img src="@(string.IsNullOrEmpty(item.NguoiDung.AnhDaiDien) ? "/images/default-avatar.png" : item.NguoiDung.AnhDaiDien)" class="w-100 h-100" style="object-fit: cover;" alt="Avatar">
                        </div>
                        <div class="card-body" style="padding: 14px 16px;">
                            <div class="d-flex justify-content-between mb-1">
                                <span style="font-size: 14px; font-weight: 700;">@item.NguoiDung.HoTen</span>
                                <span style="font-size: 14px; font-weight: 700; color: #1557b0;">@item.GiaThue.ToString("N0")đ</span>
                            </div>
                            <div style="font-size: 12px; color: #888; margin-bottom: 10px;">
                                📍 @item.PhuongXa.TinhThanh.TenTinh
                            </div>
                            <a asp-controller="Profile" asp-action="ChiTiet" asp-route-id="@item.MaHDV" class="btn w-100" style="border: 1.5px solid #c8d2e8; font-size: 13px; font-weight: 600;">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>