@model HeThongDatLich.Models.HOSOHDV
@{
    ViewData["Title"] = "Profile HDV " + Model.NguoiDung.HoTen;
}

<div class="content-wrap" style="max-width: 1100px; margin: 32px auto; padding: 0 24px;">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 p-4 text-center" style="border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.06);">
                <img src="@Model.NguoiDung.AnhDaiDien" class="rounded-circle mx-auto mb-3" style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #e8eaf0;">
                <h4 style="font-weight: 700; color: #1a1a2e;">@Model.NguoiDung.HoTen</h4>
                <p class="text-muted small">📍 @Model.PhuongXa.TenPhuongXa, @Model.PhuongXa.TinhThanh.TenTinh</p>
                <h5 style="color: #1557b0; font-weight: 700;">@Model.GiaThue.ToString("N0")đ <span class="small text-muted fw-normal">/ngày</span></h5>
                
                <a asp-controller="DatLich" asp-action="Index" asp-route-maHdv="@Model.MaHDV" class="btn w-100 mt-3" style="background: #1557b0; color: white; font-weight: 600;">Tiến hành Đặt lịch</a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 p-4 mb-4" style="border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.06);">
                <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 15px;">Giới thiệu bản thân</h5>
                <p><strong>Kinh nghiệm:</strong> @Model.KinhNghiem năm</p>
                <p><strong>Ngôn ngữ:</strong> @Model.NgonNgu.TenNgonNgu</p>
                <p style="white-space: pre-line; color: #555;">@Model.GioiThieu</p>
            </div>

            <div class="card border-0 p-4" style="border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.06);">
                <h5 style="font-weight: 700; color: #1a1a2e; margin-bottom: 15px;">Đánh giá & Phản hồi</h5>
                
                <form asp-controller="DanhGia" asp-action="GuiDanhGia" method="post" class="mb-4 p-3" style="background: #f8f9fa; border-radius: 8px;">
                    <input type="hidden" name="maDatLich" value="1" /> <div class="mb-2">
                    <label class="fw-bold small">Chất lượng chuyến đi (Số sao)</label>
                    <select name="soSao" class="form-select form-select-sm w-25">
                        <option value="5">⭐⭐⭐⭐⭐ Tuyệt vời</option>
                        <option value="4">⭐⭐⭐⭐ Tốt</option>
                        <option value="3">⭐⭐⭐ Tạm được</option>
                    </select>
                </div>
                <div class="mb-2">
                    <textarea name="noiDung" class="form-control" rows="3" placeholder="Chia sẻ trải nghiệm của bạn..."></textarea>
                </div>
                <button type="submit" class="btn btn-sm btn-success">Gửi Đánh Giá</button>
            </form>
        </div>
    </div>
</div>
</div>