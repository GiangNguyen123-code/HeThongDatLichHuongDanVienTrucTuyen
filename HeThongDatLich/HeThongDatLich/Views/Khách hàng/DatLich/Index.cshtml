@{
    ViewData["Title"] = "Đặt lịch chuyến đi";
}

<div class="content-wrap" style="max-width: 800px; margin: 32px auto; padding: 0 24px;">
    <h3 style="font-weight: 700; color: #1a1a2e; margin-bottom: 20px;">Hoàn tất Đặt lịch</h3>
    
    <div class="card border-0 p-4" style="border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.06);">
        <hr />
        <h5 style="font-weight: 700;">Thanh toán & Mã giảm giá</h5>
        <div class="d-flex justify-content-between mb-2">
            <span>Tạm tính:</span>
            <strong id="LabelTongTienGoc" data-giagoc="1000000">1,000,000 đ</strong>
        </div>

        <div class="input-group mb-3">
            <input type="text" id="InputVoucher" class="form-control" placeholder="Nhập mã ưu đãi (Ví dụ: SUMMER2024)">
            <button class="btn btn-dark" type="button" id="BtnApDungVoucher">Áp dụng</button>
        </div>
        <div id="VoucherMessage" class="small mb-2 fw-bold"></div>

        <div class="d-flex justify-content-between mb-2 text-success">
            <span>Số tiền giảm:</span>
            <strong id="LabelSoTienGiam">0 đ</strong>
        </div>
        <div class="d-flex justify-content-between mb-3">
            <span class="fs-5 fw-bold">Tổng thanh toán:</span>
            <strong id="LabelTongTienCuoi" class="text-danger fs-5">1,000,000 đ</strong>
        </div>

        <button class="btn w-100" style="background: #1557b0; color: white; font-weight: 600; padding: 12px;">XÁC NHẬN ĐẶT LỊCH</button>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#BtnApDungVoucher").click(function () {
                var code = $("#InputVoucher").val();
                var total = parseFloat($("#LabelTongTienGoc").data("giagoc"));
                
                $.post('/DatLich/KiemTraVoucher', { tenVoucher: code, tongTienTamTinh: total }, function(res) {
                    if(res.success) {
                        $("#VoucherMessage").removeClass("text-danger").addClass("text-success").text(res.message);
                        $("#LabelSoTienGiam").text("-" + res.soTienGiam.toLocaleString('vi-VN') + " đ");
                        $("#LabelTongTienCuoi").text(res.tongTienMoi.toLocaleString('vi-VN') + " đ");
                    } else {
                        $("#VoucherMessage").removeClass("text-success").addClass("text-danger").text(res.message);
                    }
                });
            });
        });
    </script>
}