@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – BookingTravel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --ink:       #1a1a2e;
            --blue:      #2563eb;
            --blue-dark: #1d4ed8;
            --blue-soft: #eff6ff;
            --gray-100:  #f8fafc;
            --gray-200:  #e2e8f0;
            --gray-400:  #94a3b8;
            --gray-600:  #475569;
            --red:       #ef4444;
            --white:     #ffffff;
            --radius:    12px;
            --shadow:    0 4px 24px rgba(0,0,0,.08);
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            background: var(--gray-100);
        }

        /* ── LAYOUT ─────────────────────────────────── */
        .page {
            display: grid;
            grid-template-columns: 1fr 480px;
            min-height: 100vh;
        }

        /* ── LEFT PANEL ─────────────────────────────── */
        .panel-left {
            position: relative;
            overflow: hidden;
            background: var(--ink);
        }

        .panel-left img.bg {
            position: absolute; inset: 0;
            width: 100%; height: 100%;
            object-fit: cover;
            opacity: .72;
            transition: transform 8s ease;
        }

        .panel-left:hover img.bg { transform: scale(1.04); }

        .overlay {
            position: absolute; inset: 0;
            background: linear-gradient(135deg,
                rgba(15,23,42,.72) 0%,
                rgba(30,58,138,.45) 60%,
                transparent 100%);
        }

        .left-content {
            position: relative; z-index: 2;
            display: flex; flex-direction: column;
            height: 100%;
            padding: 36px 48px;
        }

        .logo {
            display: flex; align-items: center; gap: 10px;
            color: var(--white);
            font-size: 18px; font-weight: 600;
            letter-spacing: -.3px;
        }

        .logo-icon {
            width: 32px; height: 32px;
            background: var(--blue);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
        }

        .logo-icon svg { width: 18px; height: 18px; }

        .left-body {
            flex: 1;
            display: flex; flex-direction: column;
            justify-content: flex-end;
            padding-bottom: 64px;
        }

        .left-body h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 3.2vw, 2.8rem);
            line-height: 1.18;
            color: var(--white);
            margin-bottom: 18px;
        }

        .left-body p {
            font-size: 15px; font-weight: 300;
            color: rgba(255,255,255,.76);
            max-width: 340px; line-height: 1.65;
        }

        .social-proof {
            display: flex; align-items: center; gap: 12px;
            margin-top: 40px;
        }

        .avatars { display: flex; }

        .avatars img {
            width: 36px; height: 36px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,.5);
            margin-left: -10px;
            object-fit: cover;
        }

        .avatars img:first-child { margin-left: 0; }

        .proof-text {
            font-size: 13px; color: rgba(255,255,255,.8); line-height: 1.5;
        }

        .proof-text strong { color: var(--white); font-weight: 600; }

        /* ── RIGHT PANEL ─────────────────────────────── */
        .panel-right {
            background: var(--white);
            display: flex; align-items: center; justify-content: center;
            padding: 40px 48px;
        }

        .form-box { width: 100%; max-width: 360px; }

        .form-box h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2rem; font-weight: 700;
            color: var(--ink); margin-bottom: 6px;
        }

        .form-box .subtitle {
            font-size: 14px; color: var(--gray-600);
            margin-bottom: 28px;
        }

        /* Social buttons */
        .social-row {
            display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
            margin-bottom: 24px;
        }

        .btn-social {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            height: 44px; border-radius: var(--radius);
            border: 1.5px solid var(--gray-200);
            background: var(--white);
            font-size: 14px; font-weight: 500; color: var(--ink);
            cursor: pointer;
            transition: border-color .2s, box-shadow .2s, background .15s;
            text-decoration: none;
        }

        .btn-social:hover {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37,99,235,.08);
            background: var(--blue-soft);
        }

        .btn-social img { width: 18px; height: 18px; }

        /* Divider */
        .divider {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 24px;
        }

        .divider::before, .divider::after {
            content: ''; flex: 1;
            height: 1px; background: var(--gray-200);
        }

        .divider span {
            font-size: 12px; color: var(--gray-400); white-space: nowrap;
        }

        /* Form fields */
        .field { margin-bottom: 18px; }

        .field label {
            display: block;
            font-size: 13px; font-weight: 500;
            color: var(--ink); margin-bottom: 6px;
        }

        .input-wrap {
            position: relative; display: flex; align-items: center;
        }

        .input-wrap .icon {
            position: absolute; left: 14px;
            color: var(--gray-400);
            display: flex; pointer-events: none;
        }

        .input-wrap input {
            width: 100%; height: 48px;
            padding: 0 44px 0 44px;
            border: 1.5px solid var(--gray-200);
            border-radius: var(--radius);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px; color: var(--ink);
            background: var(--white);
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

        .input-wrap input::placeholder { color: var(--gray-400); }

        .input-wrap input:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(37,99,235,.12);
        }

        .input-wrap .toggle-pw {
            position: absolute; right: 14px;
            background: none; border: none;
            color: var(--gray-400); cursor: pointer;
            display: flex; padding: 0;
            transition: color .2s;
        }

        .input-wrap .toggle-pw:hover { color: var(--blue); }

        /* Row with label + link */
        .field-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 6px;
        }

        .field-header label { margin-bottom: 0; }

        .field-header a {
            font-size: 12px; color: var(--blue);
            text-decoration: none; font-weight: 500;
        }

        .field-header a:hover { text-decoration: underline; }

        /* Remember */
        .remember-row {
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 22px;
        }

        .remember-row input[type="checkbox"] {
            width: 16px; height: 16px; accent-color: var(--blue); cursor: pointer;
        }

        .remember-row label {
            font-size: 13px; color: var(--gray-600); cursor: pointer;
        }

        /* Submit */
        .btn-primary {
            width: 100%; height: 50px;
            background: var(--blue);
            color: var(--white);
            border: none; border-radius: var(--radius);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px; font-weight: 600;
            cursor: pointer;
            transition: background .2s, transform .1s, box-shadow .2s;
            box-shadow: 0 4px 14px rgba(37,99,235,.32);
        }

        .btn-primary:hover {
            background: var(--blue-dark);
            box-shadow: 0 6px 18px rgba(37,99,235,.42);
        }

        .btn-primary:active { transform: scale(.985); }

        /* Bottom text */
        .form-footer {
            text-align: center; margin-top: 22px;
            font-size: 13px; color: var(--gray-600);
        }

        .form-footer a {
            color: var(--blue); font-weight: 600; text-decoration: none;
        }

        .form-footer a:hover { text-decoration: underline; }

        /* Links row */
        .links-row {
            display: flex; justify-content: center; gap: 20px;
            margin-top: 32px;
        }

        .links-row a {
            font-size: 12px; color: var(--gray-400); text-decoration: none;
            transition: color .2s;
        }

        .links-row a:hover { color: var(--blue); }

        /* Error message */
        .alert-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: var(--radius);
            padding: 12px 16px;
            font-size: 13px; color: #b91c1c;
            margin-bottom: 18px;
            display: flex; align-items: flex-start; gap: 8px;
        }

        /* ── RESPONSIVE ───────────────────────────────── */
        @@media (max-width: 860px) {
            .page { grid-template-columns: 1fr; }
            .panel-left { display: none; }
            .panel-right { padding: 40px 24px; min-height: 100vh; }
        }
    </style>
</head>
<body>
<div class="page">

    <!-- LEFT: Hero panel -->
    <div class="panel-left">
        <img class="bg"
             src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=1200&auto=format&fit=crop"
             alt="Vịnh Hạ Long" />
        <div class="overlay"></div>
        <div class="left-content">
            <div class="logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 2a14.5 14.5 0 0 0 0 20A14.5 14.5 0 0 0 12 2"/>
                        <path d="M2 12h20"/>
                    </svg>
                </div>
                BookingTravel
            </div>

            <div class="left-body">
                <h1>Khám phá thế giới như<br/>một người bản địa.</h1>
                <p>Kết nối với những hướng dẫn viên chuyên nghiệp để
                   có những trải nghiệm du lịch chân thực nhất.</p>

                <div class="social-proof">
                    <div class="avatars">
                        <img src="https://i.pravatar.cc/60?img=47" alt="" />
                        <img src="https://i.pravatar.cc/60?img=32" alt="" />
                        <img src="https://i.pravatar.cc/60?img=15" alt="" />
                    </div>
                    <div class="proof-text">
                        <strong>Hơn 10.000+</strong> khách du lịch<br/>đã tin tưởng chúng tôi
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Form panel -->
    <div class="panel-right">
        <div class="form-box">
            <h2>Chào mừng trở lại</h2>
            <p class="subtitle">Đăng nhập để quản lý các chuyến đi của bạn</p>

            <!-- Social login buttons -->
            <div class="social-row">
                <a href="#" class="btn-social">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" />
                    Google
                </a>
                <a href="#" class="btn-social">
                    <img src="https://www.svgrepo.com/show/452197/facebook.svg" alt="Facebook" />
                    Facebook
                </a>
            </div>

            <div class="divider"><span>Hoặc đăng nhập bằng Email</span></div>

            <!-- Validation errors -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-error">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    <span>
                        @foreach (var error in ViewData.ModelState.Values
                                      .SelectMany(v => v.Errors))
                        {
                            @error.ErrorMessage
                        }
                    </span>
                </div>
            }

            <!-- Login form — posts to TaiKhoanController.DangNhapTK [POST] -->
            <form method="post" asp-action="DangNhapTK" asp-controller="TaiKhoan">
                @Html.AntiForgeryToken()

                <div class="field">
                    <label for="tenDangNhap">Email hoặc Tên đăng nhập</label>
                    <div class="input-wrap">
                        <span class="icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </span>
                        <input type="text" id="tenDangNhap" name="tenDangNhap"
                               placeholder="example@localguide.com"
                               autocomplete="username" required />
                    </div>
                </div>

                <div class="field">
                    <div class="field-header">
                        <label for="matKhau">Mật khẩu</label>
                        <a href="#">Quên mật khẩu?</a>
                    </div>
                    <div class="input-wrap">
                        <span class="icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input type="password" id="matKhau" name="matKhau"
                               placeholder="••••••••"
                               autocomplete="current-password" required />
                        <button type="button" class="toggle-pw" onclick="togglePassword(this)"
                                aria-label="Hiện/Ẩn mật khẩu">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 class="icon-eye">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="remember-row">
                    <input type="checkbox" id="ghiNho" name="ghiNho" />
                    <label for="ghiNho">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn-primary">Đăng nhập</button>
            </form>

            <p class="form-footer">
                Chưa có tài khoản?
                <a asp-action="DangKyTK" asp-controller="TaiKhoan">Đăng ký ngay</a>
            </p>

            <div class="links-row">
                <a href="#">Điều khoản dịch vụ</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Hỗ trợ</a>
            </div>
        </div>
    </div>

</div>

<script>
function togglePassword(btn) {
    const input = btn.closest('.input-wrap').querySelector('input');
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.style.color = isHidden ? 'var(--blue)' : 'var(--gray-400)';
}
</script>
</body>
</html>
