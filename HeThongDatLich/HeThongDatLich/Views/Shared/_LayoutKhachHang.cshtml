@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var userName = HttpContextAccessor.HttpContext.Session.GetString("UserName");
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");

    string firstLetter = "U";
    if (!string.IsNullOrEmpty(userName))
    {
        var words = userName.Trim().Split(' ');
        firstLetter = words[words.Length - 1].Substring(0, 1).ToUpper();
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingTravel</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Be Vietnam Pro', sans-serif; color: #1a1a2e; background: #f5f6fa; }
        .bt-nav { display: flex; align-items: center; gap: 32px; padding: 0 40px; height: 60px; background: #fff; border-bottom: 1px solid #e8eaf0; position: sticky; top: 0; z-index: 100; }
        .bt-nav .brand { font-size: 20px; font-weight: 700; color: #1557b0; text-decoration: none; }
        .bt-nav .nav-links { display: flex; gap: 24px; list-style: none; flex: 1; }
        .bt-nav .nav-links a { font-size: 14px; font-weight: 500; color: #555; text-decoration: none; padding: 4px 0; transition: color .2s; }
        .bt-nav .nav-links a:hover { color: #1557b0; }
        .bt-nav .nav-right { display: flex; align-items: center; gap: 12px; margin-left: auto; }
        .btn-avatar { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #2563eb, #1557b0); color: #fff; font-weight: 600; }
        .bt-footer { background: #1a1a2e; color: #b0b8cc; padding: 48px 40px 24px; margin-top: 40px; }
    </style>
</head>
<body>
    <nav class="bt-nav">
        <a class="brand" asp-action="Index" asp-controller="KhachHangHome">BookingTravel</a>
        
        <ul class="nav-links">
            <li><a asp-action="Index" asp-controller="KhachHangHome">Trang chủ Khách</a></li>
            
            @* Fix nhẹ điều kiện phòng hờ Session lưu quyền là số "2" hoặc chữ "KhachHang" *@
            @if (userRole == "KhachHang" || userRole == "2")
            {
                <li><a asp-action="LichSu" asp-controller="KhachHangDonDat">Quản lý chuyến đi</a></li>
                <li><a asp-action="Index" asp-controller="KhachHangProfile">Hồ sơ cá nhân</a></li>
            }
        </ul>
        
        <div class="nav-right">
            @if (string.IsNullOrEmpty(userName))
            {
                <a asp-action="DangNhapTK" asp-controller="TaiKhoan" style="background:#1557b0; color:#fff; padding:6px 16px; border-radius:6px; text-decoration:none; font-size:13px; font-weight:600;">Đăng nhập</a>
            }
            else
            {
                <div style="display:flex; align-items:center; gap:12px;">
                    <a asp-action="Index" asp-controller="KhachHangProfile" style="display:flex; align-items:center; gap:8px; text-decoration:none; color:inherit; cursor:pointer;" title="Xem thông tin tài khoản">
                        <div class="btn-avatar">@firstLetter</div>
                        <span style="font-size:13px; font-weight:500; transition: color 0.2s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='inherit'">Hi, @userName</span>
                    </a>
                    
                    <a asp-action="DangXuat" asp-controller="TaiKhoan" style="color:#ef4444; font-size:14px; margin-left: 8px;" title="Đăng xuất">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    </a>
                </div>
            }
        </div>
    </nav>

    @RenderBody()

    <footer class="bt-footer">
        <div style="text-align:center; font-size:13px;">
            © 2026 BookingTravel. Dành riêng cho trải nghiệm Khách Hàng.
        </div>
    </footer>
</body>
</html>