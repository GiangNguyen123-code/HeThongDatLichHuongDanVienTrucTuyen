<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LocalGuide</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* Toàn bộ CSS từ file Index của bạn paste vào đây */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Be Vietnam Pro', sans-serif; color: #1a1a2e; background: #f5f6fa; }
        .bt-nav { display: flex; align-items: center; gap: 32px; padding: 0 40px; height: 60px; background: #fff; border-bottom: 1px solid #e8eaf0; position: sticky; top: 0; z-index: 100; }
        .bt-nav .brand { font-size: 20px; font-weight: 700; color: #1557b0; text-decoration: none; }
        .bt-nav .nav-links { display: flex; gap: 24px; list-style: none; flex: 1; margin-bottom: 0;}
        .bt-nav .nav-links a { font-size: 14px; font-weight: 500; color: #555; text-decoration: none; padding: 4px 0; transition: color .2s; }
        .bt-nav .nav-links a:hover { color: #1557b0; }
        .bt-nav .nav-right { display: flex; align-items: center; gap: 12px; margin-left: auto; }
        .btn-signin { background: #1557b0; color: #fff; border: none; border-radius: 6px; padding: 8px 18px; font-size: 13px; font-weight: 600; }
        .bt-footer { background: #1a1a2e; color: #b0b8cc; padding: 48px 40px 24px; margin-top: auto; }
        
        /* Giữ lại toàn bộ các class CSS hero, sidebar, guide-grid, guide-card... của bạn ở đây */
        /* ... (Copy các style liên quan đến hero, sidebar, card từ file cũ của bạn vào đây) ... */
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="bt-nav">
        <a class="brand" asp-controller="Timkiem" asp-action="Index">BookingTravel</a>
        <ul class="nav-links">
            <li><a href="#" class="active">Home</a></li>
            <li><a href="#">Quản lý lịch</a></li>
            <li><a href="#">HDV</a></li>
            <li><a asp-controller="ThongKe" asp-action="DoanhThu">Admin (Thống kê)</a></li>
        </ul>
        <div class="nav-right">
            <button class="btn-signin">Sign In</button>
            <div class="btn-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: #f5f6fa; display: flex; align-items: center; justify-content: center;"><i class="fa fa-user"></i></div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bt-footer mt-auto">
        <div class="text-center" style="font-size: 12px; color: #5a6480;">
            © 2026 LocalGuide VN. Tất cả quyền được bảo lưu.
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>