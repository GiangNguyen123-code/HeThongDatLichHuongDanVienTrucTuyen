@{
    ViewData["Title"] = "Home Page";
}

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Be Vietnam Pro', sans-serif;
        color: #1a1a2e;
        background: #f5f6fa;
    }

    /* ───── NAVBAR ───── */
    .bt-nav {
        display: flex;
        align-items: center;
        gap: 32px;
        padding: 0 40px;
        height: 60px;
        background: #fff;
        border-bottom: 1px solid #e8eaf0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .bt-nav .brand {
        font-size: 20px;
        font-weight: 700;
        color: #1557b0;
        white-space: nowrap;
        text-decoration: none;
    }

    .bt-nav .nav-links {
        display: flex;
        gap: 24px;
        list-style: none;
        flex: 1;
    }

    .bt-nav .nav-links a {
        font-size: 14px;
        font-weight: 500;
        color: #555;
        text-decoration: none;
        padding: 4px 0;
        border-bottom: 2px solid transparent;
        transition: color .2s, border-color .2s;
    }

    .bt-nav .nav-links a:hover,
    .bt-nav .nav-links a.active {
        color: #1557b0;
        border-bottom-color: #1557b0;
    }

    .bt-nav .nav-right {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-left: auto;
    }

    .bt-nav .search-box {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f0f2f8;
        border-radius: 20px;
        padding: 6px 16px;
        font-size: 13px;
        color: #999;
        cursor: text;
        min-width: 220px;
    }

    .bt-nav .search-box i { font-size: 13px; }

    .bt-nav .currency {
        font-size: 13px;
        font-weight: 500;
        color: #555;
        cursor: pointer;
    }

    .bt-nav .lang-btn {
        width: 32px; height: 32px;
        border-radius: 50%;
        border: 1px solid #dde0ea;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: #555;
        font-size: 15px;
    }

    .btn-signin {
        background: #1557b0;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }

    .btn-signin:hover { background: #0d47a1; }

    .btn-avatar {
        width: 32px; height: 32px;
        border-radius: 50%;
        border: 1px solid #dde0ea;
        background: #f5f6fa;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: #555;
    }

    /* ───── HERO ───── */
    .hero {
        position: relative;
        height: 380px;
        background: url('https://images.unsplash.com/photo-1528127269322-539801943592?w=1600&q=80') center/cover no-repeat;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #fff;
        gap: 10px;
    }

    .hero::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,.35) 0%, rgba(0,0,0,.55) 100%);
    }

    .hero * { position: relative; z-index: 1; }

    .hero h1 {
        font-size: 34px;
        font-weight: 700;
        line-height: 1.3;
        max-width: 600px;
        text-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    .hero p {
        font-size: 15px;
        font-weight: 300;
        opacity: .9;
        margin-bottom: 8px;
    }

    .hero-search {
        display: flex;
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        width: 620px;
        box-shadow: 0 8px 32px rgba(0,0,0,.25);
    }

    .hero-search .hs-field {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 20px;
        border-right: 1px solid #e8eaf0;
    }

    .hero-search .hs-field i { color: #1557b0; font-size: 16px; }

    .hero-search .hs-field input {
        border: none;
        outline: none;
        font-size: 14px;
        color: #333;
        width: 100%;
        height: 52px;
        font-family: inherit;
    }

    .hero-search .hs-field input::placeholder { color: #aaa; }

    .hero-search .btn-search {
        background: #1557b0;
        color: #fff;
        border: none;
        padding: 0 28px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background .2s;
    }

    .hero-search .btn-search:hover { background: #0d47a1; }

    /* ───── CONTENT AREA ───── */
    .content-wrap {
        max-width: 1100px;
        margin: 32px auto;
        padding: 0 24px;
        display: flex;
        gap: 28px;
        align-items: flex-start;
    }

    /* ───── SIDEBAR FILTER ───── */
    .sidebar {
        width: 210px;
        flex-shrink: 0;
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .sidebar-header span {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #888;
    }

    .sidebar-header a {
        font-size: 12px;
        color: #1557b0;
        text-decoration: none;
    }

    .filter-group { margin-bottom: 20px; }

    .filter-group label.group-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
    }

    .filter-option {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        cursor: pointer;
    }

    .filter-option input[type="checkbox"] {
        width: 16px; height: 16px;
        accent-color: #1557b0;
        cursor: pointer;
    }

    .filter-option span {
        font-size: 13px;
        color: #444;
    }

    .price-range {
        margin-top: 6px;
    }

    .price-range input[type="range"] {
        width: 100%;
        accent-color: #1557b0;
        margin: 8px 0;
    }

    .price-labels {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: #888;
    }

    .star-option {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        cursor: pointer;
    }

    .star-option input[type="radio"] {
        accent-color: #1557b0;
        cursor: pointer;
    }

    .stars { color: #f5a623; font-size: 14px; }
    .star-option .star-label { font-size: 12px; color: #666; }

    /* ───── GUIDE LISTING ───── */
    .listing { flex: 1; }

    .listing-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .listing-header h2 {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
    }

    .listing-header h2 span {
        font-size: 14px;
        font-weight: 400;
        color: #888;
        margin-left: 6px;
    }

    .sort-select {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #555;
        cursor: pointer;
    }

    .sort-select select {
        border: none;
        outline: none;
        font-size: 13px;
        color: #1557b0;
        font-weight: 600;
        font-family: inherit;
        background: transparent;
        cursor: pointer;
    }

    /* ───── GUIDE GRID ───── */
    .guide-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .guide-card {
        background: #fff;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        transition: transform .2s, box-shadow .2s;
    }

    .guide-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 28px rgba(0,0,0,.13);
    }

    .card-img {
        position: relative;
        height: 160px;
        overflow: hidden;
        background: #e8eaf0;
    }

    .card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
    }

    .rating-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0,0,0,.62);
        color: #fff;
        border-radius: 20px;
        padding: 3px 9px;
        font-size: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .rating-badge i { color: #f5a623; font-size: 11px; }

    .card-body { padding: 14px 16px 16px; }

    .card-name-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2px;
    }

    .card-name {
        font-size: 14px;
        font-weight: 700;
        color: #1a1a2e;
    }

    .card-price {
        font-size: 14px;
        font-weight: 700;
        color: #1557b0;
        white-space: nowrap;
    }

    .card-location {
        font-size: 12px;
        color: #888;
        margin-bottom: 10px;
    }

    .card-location .price-unit {
        font-size: 11px;
        font-weight: 400;
        color: #aaa;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 10px;
    }

    .tag {
        background: #eef2ff;
        color: #1557b0;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }

    .tag.green {
        background: #e6f9f0;
        color: #1a8a52;
    }

    .exp-badge {
        display: inline-block;
        background: #f0f2f8;
        color: #555;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        margin-bottom: 12px;
    }

    .btn-detail {
        display: block;
        width: 100%;
        padding: 9px;
        border: 1.5px solid #c8d2e8;
        border-radius: 8px;
        background: #fff;
        color: #1a1a2e;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: background .2s, border-color .2s, color .2s;
        text-decoration: none;
    }

    .btn-detail:hover {
        background: #1557b0;
        border-color: #1557b0;
        color: #fff;
    }

    /* ───── PAGINATION ───── */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        margin-bottom: 40px;
    }

    .page-btn {
        width: 36px; height: 36px;
        border-radius: 8px;
        border: 1.5px solid #dde0ea;
        background: #fff;
        color: #555;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .2s;
        text-decoration: none;
    }

    .page-btn:hover { border-color: #1557b0; color: #1557b0; }
    .page-btn.active { background: #1557b0; border-color: #1557b0; color: #fff; }

    /* ───── FOOTER ───── */
    .bt-footer {
        background: #1a1a2e;
        color: #b0b8cc;
        padding: 48px 40px 24px;
    }

    .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 36px;
    }

    .footer-brand .brand {
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        text-decoration: none;
        display: block;
        margin-bottom: 14px;
    }

    .footer-brand p {
        font-size: 13px;
        line-height: 1.7;
        color: #8a96b0;
    }

    .footer-col h4 {
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 14px;
        letter-spacing: .04em;
    }

    .footer-col a {
        display: block;
        font-size: 13px;
        color: #8a96b0;
        text-decoration: none;
        margin-bottom: 8px;
        transition: color .2s;
    }

    .footer-col a:hover { color: #fff; }

    .social-icons {
        display: flex;
        gap: 14px;
        margin-top: 4px;
    }

    .social-icons a {
        width: 34px; height: 34px;
        border-radius: 50%;
        border: 1px solid #2e3550;
        display: flex; align-items: center; justify-content: center;
        color: #8a96b0;
        font-size: 14px;
        text-decoration: none;
        transition: border-color .2s, color .2s;
    }

    .social-icons a:hover { border-color: #4a7fd4; color: #4a7fd4; }

    .footer-bottom {
        max-width: 1100px;
        margin: 0 auto;
        border-top: 1px solid #2e3550;
        padding-top: 20px;
        text-align: center;
        font-size: 12px;
        color: #5a6480;
    }
</style>

<!-- ═══════════════ NAVBAR ═══════════════ -->
<nav class="bt-nav">
    <a class="brand" href="#">BookingTravel</a>
    <ul class="nav-links">
        <li><a href="#" class="active">Home</a></li>
        <li><a href="#">Quản lý lịch</a></li>
        <li><a href="#">HDV</a></li>
        <li><a href="#">Admin</a></li>
        <li><a href="#">Help</a></li>
    </ul>
    <div class="nav-right">
        <div class="search-box">
            <i class="fa fa-search"></i>
            Tìm thành phố, hướng dẫn viên...
        </div>
        <span class="currency">VN/USD</span>
        <div class="lang-btn"><i class="fa fa-globe"></i></div>
        <button class="btn-signin">Sign In</button>
        <div class="btn-avatar"><i class="fa fa-user"></i></div>
    </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="hero">
    <h1>Tìm hướng dẫn viên địa phương cho chuyến đi<br>của bạn</h1>
    <p>Khám phá vẻ đẹp tiềm ẩn qua góc nhìn của người bản xứ chuyên nghiệp.</p>
    <div class="hero-search">
        <div class="hs-field">
            <i class="fa fa-map-marker-alt"></i>
            <input type="text" placeholder="Bạn muốn đi đâu?">
        </div>
        <div class="hs-field" style="border-right:none;">
            <i class="fa-regular fa-calendar"></i>
            <input type="text" placeholder="Ngày bắt đầu">
        </div>
        <button class="btn-search">
            <i class="fa fa-search"></i> Tìm kiếm
        </button>
    </div>
</section>

<!-- ═══════════════ CONTENT ═══════════════ -->
<div class="content-wrap">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <span>Bộ Lọc</span>
            <a href="#">Xoá tất cả</a>
        </div>

        <div class="filter-group">
            <label class="group-label">Khu vực</label>
            <label class="filter-option">
                <input type="checkbox"> <span>Miền Bắc</span>
            </label>
            <label class="filter-option">
                <input type="checkbox" checked> <span>Miền Trung</span>
            </label>
            <label class="filter-option">
                <input type="checkbox"> <span>Miền Nam</span>
            </label>
        </div>

        <div class="filter-group">
            <label class="group-label">Ngôn ngữ</label>
            <label class="filter-option">
                <input type="checkbox" checked> <span>Tiếng Việt</span>
            </label>
            <label class="filter-option">
                <input type="checkbox" checked> <span>Tiếng Anh</span>
            </label>
            <label class="filter-option">
                <input type="checkbox"> <span>Tiếng Nhật</span>
            </label>
        </div>

        <div class="filter-group">
            <label class="group-label">Mức giá / giờ</label>
            <div class="price-range">
                <input type="range" min="100" max="1000" value="600">
                <div class="price-labels">
                    <span>100k</span>
                    <span>1.000k</span>
                </div>
            </div>
        </div>

        <div class="filter-group">
            <label class="group-label">Đánh giá</label>
            <label class="star-option">
                <input type="radio" name="rating" checked>
                <span class="stars">★★★★★</span>
            </label>
            <label class="star-option">
                <input type="radio" name="rating">
                <span class="stars">★★★★</span>
                <span class="star-label">trở lên</span>
            </label>
        </div>
    </aside>

    <!-- LISTING -->
    <div class="listing">
        <div class="listing-header">
            <h2>Hướng dẫn viên tại Đà Nẵng <span>(124 kết quả)</span></h2>
            <div class="sort-select">
                Sắp xếp theo:
                <select>
                    <option>Được đánh giá cao</option>
                    <option>Giá thấp nhất</option>
                    <option>Kinh nghiệm nhiều nhất</option>
                </select>
            </div>
        </div>

        <div class="guide-grid">

            <!-- Card 1 -->
            <div class="guide-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1580894742597-87bc8789db3d?w=400&q=80" alt="Nguyễn Thu Hà">
                    <div class="rating-badge"><i class="fa fa-star"></i> 4.9</div>
                </div>
                <div class="card-body">
                    <div class="card-name-row">
                        <span class="card-name">Nguyễn Thu Hà</span>
                        <span class="card-price">250.000đ</span>
                    </div>
                    <div class="card-location">
                        Đà Nẵng • Hội An <span class="price-unit">/ Mỗi giờ</span>
                    </div>
                    <div class="card-tags">
                        <span class="tag">Lịch sử</span>
                        <span class="tag">Ẩm thực</span>
                    </div>
                    <div class="exp-badge">5 năm kinh nghiệm</div>
                    <a href="#" class="btn-detail">Xem chi tiết</a>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="guide-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1552058544-f2b08422138a?w=400&q=80" alt="Trần Minh Quân">
                    <div class="rating-badge"><i class="fa fa-star"></i> 4.8</div>
                </div>
                <div class="card-body">
                    <div class="card-name-row">
                        <span class="card-name">Trần Minh Quân</span>
                        <span class="card-price">300.000đ</span>
                    </div>
                    <div class="card-location">
                        Đà Nẵng • Bà Nà Hills <span class="price-unit">/ Mỗi giờ</span>
                    </div>
                    <div class="card-tags">
                        <span class="tag">Mạo hiểm</span>
                        <span class="tag">Nhiếp ảnh</span>
                    </div>
                    <div class="exp-badge">3 năm kinh nghiệm</div>
                    <a href="#" class="btn-detail">Xem chi tiết</a>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="guide-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80" alt="Lê Bảo Anh">
                    <div class="rating-badge"><i class="fa fa-star"></i> 5.0</div>
                </div>
                <div class="card-body">
                    <div class="card-name-row">
                        <span class="card-name">Lê Bảo Anh</span>
                        <span class="card-price">500.000đ</span>
                    </div>
                    <div class="card-location">
                        Đà Nẵng • Luxury Tour <span class="price-unit">/ Mỗi giờ</span>
                    </div>
                    <div class="card-tags">
                        <span class="tag">Văn hoá</span>
                        <span class="tag">Mua sắm</span>
                    </div>
                    <div class="exp-badge">8 năm kinh nghiệm</div>
                    <a href="#" class="btn-detail">Xem chi tiết</a>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="guide-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80" alt="Phạm Hoàng Nam">
                    <div class="rating-badge"><i class="fa fa-star"></i> 4.7</div>
                </div>
                <div class="card-body">
                    <div class="card-name-row">
                        <span class="card-name">Phạm Hoàng Nam</span>
                        <span class="card-price">200.000đ</span>
                    </div>
                    <div class="card-location">
                        Đà Nẵng • Food Tour <span class="price-unit">/ Mỗi giờ</span>
                    </div>
                    <div class="card-tags">
                        <span class="tag green">Ẩm thực đêm</span>
                        <span class="tag green">Địa phương</span>
                    </div>
                    <div class="exp-badge">4 năm kinh nghiệm</div>
                    <a href="#" class="btn-detail">Xem chi tiết</a>
                </div>
            </div>

            <!-- Card 5 -->
            <div class="guide-card">
                <div class="card-img">
                    <img src="https://images.unsplash.com/photo-1601233749202-95d04d5b3c00?w=400&q=80" alt="Đặng Thuỳ Dương">
                    <div class="rating-badge"><i class="fa fa-star"></i> 4.9</div>
                </div>
                <div class="card-body">
                    <div class="card-name-row">
                        <span class="card-name">Đặng Thuỳ Dương</span>
                        <span class="card-price">220.000đ</span>
                    </div>
                    <div class="card-location">
